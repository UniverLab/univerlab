# Cache policy for Cloudflare Pages.
#
# Everything Astro emits under /_astro/ carries a content hash in its filename,
# so a changed file is a changed URL — it can be cached forever and never
# revalidated. The hand-placed assets under /fonts, /logos and /demos are not
# hashed, so they get a long-but-finite TTL that a redeploy can age out.
# HTML is deliberately absent: it must stay revalidated so a deploy is visible
# immediately.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=2592000

/logos/*
  Cache-Control: public, max-age=2592000

/demos/*
  Cache-Control: public, max-age=2592000

/favicon.svg
  Cache-Control: public, max-age=604800

/og.png
  Cache-Control: public, max-age=604800

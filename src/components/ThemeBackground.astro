---
// A fixed, behind-content canvas that lazy-loads its animation only after the
// page has fully loaded — keeping first paint light. One theme per surface.
import type { BgTheme } from '../lib/experiments';
interface Props {
  theme?: BgTheme;
  color?: string;
}
const { theme = 'drift', color = '#b9b6ae' } = Astro.props;
---
<canvas class="bg" data-theme={theme} data-color={color} aria-hidden="true"></canvas>

<script>
  import type { startBackground as Start } from '../scripts/backgrounds';
  import type { BgTheme } from '../lib/experiments';
  const run = () => {
    const canvas = document.querySelector<HTMLCanvasElement>('canvas.bg');
    if (!canvas) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    // `auto` (circadian landing) → time-of-day accent; `auto-mute` (docs) → a
    // neutral grey so the animation differentiates the tool without shouting.
    const raw = canvas.dataset.color || '#b9b6ae';
    const cs = getComputedStyle(document.documentElement);
    const tok = (name: string) => cs.getPropertyValue(name).trim();
    let color = raw;
    if (raw === 'auto') {
      color = tok('--canvas-color') || tok('--accent') || '#b9b6ae';
    } else if (raw === 'auto-mute') {
      color = tok('--canvas-mute') || tok('--ink-faint') || '#b9b6ae';
    }
    const bg = cs.getPropertyValue('--bg').trim() || '#0a0b0e';
    import('../scripts/backgrounds').then(({ startBackground }) => {
      (startBackground as typeof Start)(
        canvas,
        (canvas.dataset.theme as BgTheme) || 'drift',
        color,
        bg
      );
    });
  };
  if (document.readyState === 'complete') run();
  else window.addEventListener('load', run, { once: true });
</script>

<style>
  .bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    opacity: 0.68;
  }
</style>

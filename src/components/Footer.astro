---
import Mark from './Mark.astro';
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
---
<footer>
  <hr class="rule" />
  <div class="wrap inner">
    <div class="left">
      <Mark size={20} color="var(--ink-faint)" />
      <p class="quote">{t.footer.quote}</p>
    </div>
    <div class="right label">
      <a href="https://github.com/UniverLab">github.com/UniverLab</a>
      <span>SCI · CLI · BIO</span>
    </div>
  </div>
</footer>

<style>
  .inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
    padding-block: 2.2rem 3rem;
  }
  .left { display: flex; gap: 1rem; align-items: flex-start; max-width: 34rem; }
  .quote { margin: 0; font-family: var(--font-serif); font-style: italic; color: var(--ink-dim); font-size: 0.95rem; }
  .right { display: flex; flex-direction: column; gap: 0.55rem; text-align: right; }
  .right a { text-decoration: none; }
  .right a:hover { color: var(--ink); }
</style>

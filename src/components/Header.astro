---
import Mark from './Mark.astro';
const nav = [
  { href: '/experiments', label: 'Experiments' },
  { href: '/research', label: 'Research' },
  { href: '/manifesto', label: 'Manifesto' },
  { href: '/people', label: 'People' },
  { href: 'https://github.com/UniverLab', label: 'GitHub' },
];
const path = Astro.url.pathname;
---
<header>
  <div class="wrap bar">
    <a href="/" class="home" aria-label="UniverLab home">
      <Mark size={26} />
      <span class="word">UNIVERLAB</span>
    </a>
    <nav>
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['label', { active: path.startsWith(item.href) }]}
        >{item.label}</a>
      ))}
    </nav>
  </div>
  <hr class="rule" />
</header>

<style>
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
  }
  .home {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }
  .word {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.32em;
  }
  nav { display: flex; gap: 1.6rem; flex-wrap: wrap; }
  nav a { text-decoration: none; color: var(--ink-dim); }
  nav a:hover, nav a.active { color: var(--ink); }
</style>

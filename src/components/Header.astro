---
import Mark from './Mark.astro';
import {
  getLang,
  useTranslations,
  localizePath,
  switchLangPath,
  languages,
} from '../i18n';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const path = Astro.url.pathname;

const nav = [
  { href: localizePath('/experiments', lang), label: t.nav.experiments },
  { href: localizePath('/research', lang), label: t.nav.research },
  { href: localizePath('/manifesto', lang), label: t.nav.manifesto },
  { href: localizePath('/people', lang), label: t.nav.people },
  { href: 'https://github.com/UniverLab', label: t.nav.github, ext: true },
];
const other = lang === 'en' ? 'es' : 'en';

// Docs are English-only and have no /es mirror, so switching language from a
// docs page would 404. Send it to that experiment's page in the other locale.
const docsMatch = path.match(/^\/(?:es\/)?experiments\/([^/]+)\/docs/);
const toggleHref = docsMatch
  ? localizePath(`/experiments/${docsMatch[1]}`, other)
  : switchLangPath(Astro.url, other);

function isActive(href: string, current: string): boolean {
  if (href === '/' || href === '/es') return current === href;
  return current === href || current.startsWith(href + '/');
}
---
<header>
  <div class="wrap bar">
    <a href={localizePath('/', lang)} class="home" aria-label="UniverLab">
      <Mark size={26} />
      <span class="word">UNIVERLAB</span>
    </a>
    <nav>
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['label', { active: !item.ext && isActive(item.href, path) }]}
        >{item.label}</a>
      ))}
      <a
        class="label lang"
        href={toggleHref}
        data-set-lang={other}
        hreflang={other}
      >{languages[lang]}<span class="slash">/</span>{languages[other]}</a>
    </nav>
  </div>
  <hr class="rule" />
</header>

<script>
  // Persist an explicit language choice so the pre-paint detector honours it.
  document.querySelectorAll<HTMLAnchorElement>('a[data-set-lang]').forEach((a) => {
    a.addEventListener('click', () => {
      try {
        localStorage.setItem('univerlab-lang', a.dataset.setLang!);
      } catch (e) {}
    });
  });
</script>

<style>
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
  }
  .home { display: inline-flex; align-items: center; gap: 0.65rem; text-decoration: none; }
  .word { font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.32em; }
  nav { display: flex; gap: 1.6rem; flex-wrap: wrap; align-items: center; }
  nav a { text-decoration: none; color: var(--ink-dim); }
  nav a:hover, nav a.active { color: var(--ink); }
  .lang { display: inline-flex; gap: 0.25rem; }
  .lang .slash { color: var(--ink-faint); }
  .lang { color: var(--ink-faint); }
  .lang:hover { color: var(--ink); }
</style>

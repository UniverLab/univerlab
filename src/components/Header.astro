---
import Mark from './Mark.astro';
import {
  getLang,
  useTranslations,
  localizePath,
  switchLangPath,
  languages,
} from '../i18n';
import { experiments } from '../lib/experiments';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const path = Astro.url.pathname;

// Experiments now live at the root (/canopy, /canopy/docs, …). Detect when the
// current page is one so the "Experiments" nav item still lights up.
const seg = path.replace(/^\/es(?=\/|$)/, '').split('/').filter(Boolean)[0] ?? '';
const onExperiment = experiments.some((e) => e.id === seg);

// On docs pages the header mutates: GitHub points at the project's own repo
// (not the org), and the language toggle becomes a light/dark theme toggle
// (docs are English-only).
const docsMatch = path.match(/^\/([^/]+)\/docs/);
const docExp = docsMatch ? experiments.find((e) => e.id === docsMatch[1]) : undefined;
const isDocs = !!docExp;
const githubHref = docExp ? docExp.github : 'https://github.com/UniverLab';
// Docs inherit their project's polarity; light surfaces are paper/blueprint/studio.
const docDefaultDark = docExp
  ? !['paper', 'blueprint'].includes(docExp.surface ?? '')
  : true;

const nav = [
  { href: localizePath('/experiments', lang), label: t.nav.experiments, exp: true },
  { href: localizePath('/manifesto', lang), label: t.nav.manifesto },
  { href: localizePath('/contributors', lang), label: t.nav.people },
  { href: githubHref, label: t.nav.github, ext: true },
];
const other = lang === 'en' ? 'es' : 'en';
const toggleHref = switchLangPath(Astro.url, other);

function isActive(href: string, current: string): boolean {
  if (href === '/' || href === '/es') return current === href;
  return current === href || current.startsWith(href + '/');
}
---
<header>
  <div class="wrap bar">
    <a href={localizePath('/', lang)} class="home" aria-label="UniverLab">
      <Mark size={26} />
      <span class="word" translate="no">UNIVERLAB</span>
    </a>
    <button
      type="button"
      class="burger"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="site-nav"
    >
      <span class="bars"></span>
    </button>
    <nav id="site-nav">
      {nav.map((item) => (
        <a
          href={item.href}
          target={item.ext ? '_blank' : undefined}
          rel={item.ext ? 'noopener noreferrer' : undefined}
          class:list={['label', { active: !item.ext && (isActive(item.href, path) || (item.exp && onExperiment)) }]}
        >{item.label}</a>
      ))}
      {isDocs ? (
        <button
          type="button"
          class="label theme-toggle"
          data-doc-default-dark={String(docDefaultDark)}
          aria-label="Toggle theme"
        >{docDefaultDark ? 'LIGHT' : 'DARK'}</button>
      ) : (
        <a
          class="label lang"
          href={toggleHref}
          data-set-lang={other}
          hreflang={other}
        >{languages[other]}</a>
      )}
    </nav>
  </div>
  <hr class="rule" />
</header>

<script>
  // Persist an explicit language choice so the pre-paint detector honours it.
  document.querySelectorAll<HTMLAnchorElement>('a[data-set-lang]').forEach((a) => {
    a.addEventListener('click', () => {
      try {
        localStorage.setItem('univerlab-lang', a.dataset.setLang!);
      } catch (e) {}
    });
  });

  // Docs theme toggle: docs default to their project's polarity; the reader can
  // force light/dark. The label always shows the TARGET theme, resolved from the
  // stored override (if any) over the project default.
  const tt = document.querySelector<HTMLButtonElement>('.theme-toggle');
  if (tt) {
    const KEY = 'univerlab-doc-theme';
    const defaultDark = tt.dataset.docDefaultDark === 'true';
    let forced = '';
    try {
      forced = localStorage.getItem(KEY) || '';
    } catch (e) {}
    const current = forced || (defaultDark ? 'dark' : 'light');
    const target = current === 'dark' ? 'light' : 'dark';
    tt.textContent = target.toUpperCase();
    tt.addEventListener('click', () => {
      try {
        localStorage.setItem(KEY, target);
      } catch (e) {}
      location.reload();
    });
  }

  // Mobile nav: the burger toggles the collapsed menu open/closed.
  const burger = document.querySelector<HTMLButtonElement>('.burger');
  const siteNav = document.getElementById('site-nav');
  if (burger && siteNav) {
    const setOpen = (open: boolean) => {
      siteNav.classList.toggle('open', open);
      burger.setAttribute('aria-expanded', String(open));
    };
    burger.addEventListener('click', () =>
      setOpen(burger.getAttribute('aria-expanded') !== 'true'),
    );
    // Close after following a link or pressing Escape.
    siteNav.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false)),
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
</script>

<style>
  .bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
  }
  .home { display: inline-flex; align-items: center; gap: 0.65rem; text-decoration: none; }
  .word { font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.32em; }
  nav { display: flex; gap: 1.6rem; flex-wrap: wrap; align-items: center; }
  nav a { text-decoration: none; color: var(--ink-dim); }
  nav a:hover, nav a.active { color: var(--ink); }
  .lang, .theme-toggle { color: var(--ink-faint); }
  .lang:hover, .theme-toggle:hover { color: var(--ink); }
  /* The theme toggle is a button but must read like the mono nav labels. */
  .theme-toggle {
    border: 0; background: none; padding: 0; cursor: pointer;
    font: inherit; letter-spacing: inherit; text-transform: inherit;
  }

  /* Hamburger button — hidden until the nav no longer fits comfortably. */
  .burger {
    display: none;
    position: relative;
    width: 2.2rem;
    height: 2.2rem;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--ink-dim);
  }
  .burger:hover { color: var(--ink); }
  .burger .bars,
  .burger .bars::before,
  .burger .bars::after {
    content: '';
    position: absolute;
    left: 50%;
    width: 1.1rem;
    height: 1.5px;
    background: currentColor;
    transform: translateX(-50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .burger .bars { top: 50%; transform: translate(-50%, -50%); }
  .burger .bars::before { top: -6px; }
  .burger .bars::after { top: 6px; }
  /* Morph into an X when open. */
  .burger[aria-expanded='true'] .bars { background: transparent; }
  .burger[aria-expanded='true'] .bars::before { top: 0; transform: translateX(-50%) rotate(45deg); }
  .burger[aria-expanded='true'] .bars::after { top: 0; transform: translateX(-50%) rotate(-45deg); }

  @media (max-width: 890px) {
    .burger { display: inline-flex; }
    nav {
      display: none;
      position: absolute;
      top: calc(100% + 0.6rem);    /* float a little below the bar */
      right: 0;                    /* anchored under the burger; .wrap padding keeps it off the page edge */
      z-index: 30;
      flex-direction: column;
      align-items: flex-end;
      text-align: right;
      gap: 1.1rem;
      min-width: 11rem;
      padding: 1.1rem 1.3rem;      /* breathing room around the options */
      background: var(--bg-raise);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: 0 14px 36px rgba(0, 0, 0, 0.5);
    }
    nav.open { display: flex; }
  }
</style>

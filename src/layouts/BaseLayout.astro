---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeBackground from '../components/ThemeBackground.astro';
import type { BgTheme } from '../lib/experiments';
import { getLang, useTranslations } from '../i18n';
import '../styles/global.css';
import '../styles/surfaces.css';

interface Props {
  title: string;
  description?: string;
  bg?: BgTheme;
  bgColor?: string;
  /** Core pages: shift the palette progressively with the time of day. */
  circadian?: boolean;
  /** Docs: render the background animation in a neutral grey, not the accent. */
  mutedCanvas?: boolean;
  /** Experiment pages: a fixed visual surface (paper, tui, blueprint, …). */
  surface?: string;
  /** Extra JSON-LD for this page (e.g. SoftwareApplication, WebSite), emitted
   *  alongside the site-wide Organization graph. */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const {
  title,
  description = t.meta.description,
  bg = 'cosmic',
  bgColor,
  circadian = false,
  mutedCanvas = false,
  surface,
  structuredData,
} = Astro.props;
const canvasColor = circadian ? (mutedCanvas ? 'auto-mute' : 'auto') : bgColor;
// Surfaces that drop the ambient canvas: paper (a typeset page stays still),
// studio (a lit stage, not drift), and blueprint (cadspec's clean plan — calm
// and geometric, no animation). ghscaff (scaffold) keeps its live drawing.
const stillSurface = ['paper', 'studio', 'blueprint'].includes(surface ?? '');
const colorScheme = ['paper', 'blueprint', 'studio'].includes(surface ?? '') ? 'light' : 'dark';

// Only request the font families a given surface actually uses. Every page
// needs Inter (body) + the mono signature; `paper` adds Spectral; the grotesque
// surfaces add Space Grotesk; terminal surfaces (tui/vcs) and the core pages
// need nothing more. This keeps unused webfonts off the page entirely.
const fontFamilies = ['IBM+Plex+Mono:wght@400;500', 'Inter:wght@400;500;600'];
if (surface === 'paper') {
  fontFamilies.push('Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500');
}
if (['scaffold', 'blueprint', 'observatory', 'studio'].includes(surface ?? '')) {
  fontFamilies.push('Space+Grotesk:wght@300;400;500;600');
}
const fontHref =
  'https://fonts.googleapis.com/css2?' +
  fontFamilies.map((f) => 'family=' + f).join('&') +
  '&display=swap';

const site = Astro.site ?? new URL('https://univerlab.org');
const path = Astro.url.pathname;
const canonical = new URL(path, site).href;
const ogImage = new URL('/og.png', site).href;
// hreflang alternates — only for localized pages (docs are English-only).
const isDocs = path.includes('/docs');
const stripped = path.replace(/^\/es(?=\/|$)/, '') || '/';
const enHref = new URL(stripped, site).href;
const esHref = new URL('/es' + (stripped === '/' ? '' : stripped), site).href;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'UniverLab',
  url: site.href,
  logo: new URL('/favicon.svg', site).href,
  description: t.meta.description,
  sameAs: ['https://github.com/UniverLab'],
};
---
<!doctype html>
<html lang={lang} data-surface={surface}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content={colorScheme} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fbfbfa" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0f1115" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <!-- Type. IBM Plex Mono is the constant UniverLab signature (the mono
         labels); Inter is the default body. Per-surface display voices:
         Spectral (paper/texforge — typeset serif), Space Grotesk (scaffold,
         blueprint, observatory, studio — technical grotesque), and the mono
         itself for the terminal surfaces (tui/canopy, vcs/gitkit). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking: fetch as `print`, promote to `all` once loaded;
         `display=swap` shows fallback text immediately. -->
    <link rel="stylesheet" href={fontHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontHref} /></noscript>
    {/* Experiment banners are block ASCII tuned to DejaVu Sans Mono (see Banner.astro). */}
    {surface && (
      <link rel="preload" href="/fonts/DejaVuSansMono.ttf" as="font" type="font/ttf" crossorigin />
    )}
    {!isDocs && (
      <>
        <link rel="alternate" hreflang="en" href={enHref} />
        <link rel="alternate" hreflang="es" href={esHref} />
        <link rel="alternate" hreflang="x-default" href={enHref} />
      </>
    )}
    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="UniverLab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {structuredData &&
      (Array.isArray(structuredData) ? structuredData : [structuredData]).map((d) => (
        <script type="application/ld+json" set:html={JSON.stringify(d)} />
      ))}
    <!-- Pre-paint language detection: first-time visitors whose system is in
         Spanish are sent to /es once; an explicit choice is always respected. -->
    <script is:inline>
      (function () {
        try {
          var path = location.pathname;
          // Documentation is English-only and has no /es mirror — never redirect it.
          if (path.indexOf('/docs') !== -1) return;
          var stored = localStorage.getItem('univerlab-lang');
          var onEs = path === '/es' || path.indexOf('/es/') === 0;
          if (!stored) {
            var sys = (navigator.language || 'en').toLowerCase().slice(0, 2);
            if (sys === 'es' && !onEs) {
              localStorage.setItem('univerlab-lang', 'es');
              location.replace('/es' + (path === '/' ? '' : path));
              return;
            }
          } else if (stored === 'es' && !onEs) {
            location.replace('/es' + (path === '/' ? '' : path));
          } else if (stored === 'en' && onEs) {
            location.replace(path.replace(/^\/es/, '') || '/');
          }
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      // Celestial position — always runs so the sun/moon dot moves along the
      // header rule on every page. Circadian pages add palette + color on top.
      (function () {
        function calc() {
          var d = new Date();
          var hour = d.getHours() + d.getMinutes() / 60;
          var y = d.getFullYear();
          var kJan = new Date(y, 0, 1).getTimezoneOffset();
          var kJul = new Date(y, 6, 1).getTimezoneOffset();
          var half = 6;
          if (kJan !== kJul) {
            var southern = kJan < kJul;
            var doy = Math.floor((d - new Date(y, 0, 0)) / 86400000);
            var s = Math.cos((2 * Math.PI * (doy - 172)) / 365.25);
            if (southern) s = -s;
            half = 6 + 2.5 * s;
          }
          var sunrise = 12 - half;
          var sunset = 12 + half;
          var isDay = hour >= sunrise && hour < sunset;
          var pos;
          if (isDay) {
            pos = ((hour - sunrise) / (sunset - sunrise)) * 100;
          } else {
            var ss = hour >= sunset ? hour - sunset : hour + (24 - sunset);
            var nl = 24 - (sunset - sunrise);
            pos = (ss / nl) * 100;
          }
          document.documentElement.style.setProperty('--sun-pos', pos.toFixed(2) + '%');
          document.documentElement.dataset.celestial = isDay ? 'sun' : 'moon';
        }
        calc();
        setInterval(calc, 60000);
        document.addEventListener('visibilitychange', function () {
          if (!document.hidden) calc();
        });
      })();
    </script>
    {circadian && (
      <script is:inline>
        // Circadian palette. Polarity (light by day, dark by night) NEVER
        // interpolates across — that mid-point is grey mush with no contrast.
        // Instead: day = always light (dark ink), night = always dark (light
        // ink); within each we only interpolate WARMTH, so dawn/dusk are the warm
        // ends. The light↔dark flip is the sunrise/sunset, estimated for the
        // visitor's latitude & season (see below). Pre-paint, so no flash.
        // Both the landing and the docs are circadian.
        (function () {
          try {
            // Day: cool at noon, warm at the edges (morning/golden hour).
            // `--canvas-color`: accent-tinted dots (landing). `--canvas-mute`: a
            // neutral grey for docs, where the animation differentiates the tool
            // but must stay calm under the uniform UniverLab accent.
            var DAY_COOL = { '--bg': '#fbfbfa', '--bg-raise': '#f1f1ee', '--ink': '#1a1c1e', '--ink-dim': '#555a61', '--ink-faint': '#8b9099', '--line': '#e4e2dc', '--accent': '#9a7b16', '--canvas-color': '#b59a3a', '--canvas-mute': '#b3b4ae' };
            var DAY_WARM = { '--bg': '#f7efe4', '--bg-raise': '#efe5d6', '--ink': '#241f18', '--ink-dim': '#5f574b', '--ink-faint': '#948975', '--line': '#e6dac6', '--accent': '#b5791f', '--canvas-color': '#cf9a3a', '--canvas-mute': '#bdb5a6' };
            // Night: warm just after dusk, cool in the deep night.
            var NIGHT_WARM = { '--bg': '#1a1822', '--bg-raise': '#221f2b', '--ink': '#ece3d6', '--ink-dim': '#b0a596', '--ink-faint': '#756b5f', '--line': '#2e2a36', '--accent': '#e8a24a', '--canvas-color': '#e0a24a', '--canvas-mute': '#565160' };
            var NIGHT_COOL = { '--bg': '#0f1115', '--bg-raise': '#15181d', '--ink': '#e3e6e8', '--ink-dim': '#a8adb5', '--ink-faint': '#6b7178', '--line': '#23262c', '--accent': '#e6c84a', '--canvas-color': '#d3bf72', '--canvas-mute': '#474a54' };

            function hx(c) { return [parseInt(c.slice(1, 3), 16), parseInt(c.slice(3, 5), 16), parseInt(c.slice(5, 7), 16)]; }
            function lerp(c1, c2, t) {
              var x = hx(c1), y = hx(c2);
              function h2(n) { return ('0' + Math.round(n).toString(16)).slice(-2); }
              return '#' + h2(x[0] + (y[0] - x[0]) * t) + h2(x[1] + (y[1] - x[1]) * t) + h2(x[2] + (y[2] - x[2]) * t);
            }
            function mix(a, b, f) { var o = {}; for (var k in a) o[k] = lerp(a[k], b[k], f); return o; }

            function calc() {
              var d = new Date();
              var hour = d.getHours() + d.getMinutes() / 60;
              var y = d.getFullYear();
              // Estimate sunrise/sunset for the visitor's latitude & season,
              // cheaply, with no geolocation prompt:
              //  - No DST observed → almost certainly low latitude → 12h day (6–18).
              //  - DST observed → mid/high latitude → seasonal swing; hemisphere
              //    from the sign of the Jan vs Jul UTC offset; a smooth cosine of
              //    the day-of-year (no month-bucket jumps), ±2.5h.
              var kJan = new Date(y, 0, 1).getTimezoneOffset();
              var kJul = new Date(y, 6, 1).getTimezoneOffset();
              var half = 6;
              if (kJan !== kJul) {
                var southern = kJan < kJul;
                var doy = Math.floor((d - new Date(y, 0, 0)) / 86400000);
                var s = Math.cos((2 * Math.PI * (doy - 172)) / 365.25); // +1 ≈ N summer solstice
                if (southern) s = -s;
                half = 6 + 2.5 * s;
              }
              var sunrise = 12 - half;
              var sunset = 12 + half;
              var isDay = hour >= sunrise && hour < sunset;
              var pal;
              if (isDay) {
                var t = (hour - sunrise) / (sunset - sunrise);
                var warm = Math.abs(t - 0.5) * 2; // warm at the edges, cool at noon
                pal = mix(DAY_COOL, DAY_WARM, warm);
              } else {
                var sinceSunset = hour >= sunset ? hour - sunset : hour + (24 - sunset);
                var nightLen = 24 - (sunset - sunrise);
                var g = nightLen > 0 ? sinceSunset / nightLen : 0;
                pal = mix(NIGHT_WARM, NIGHT_COOL, Math.min(g * 2, 1)); // warm dusk → cool night
              }
              var root = document.documentElement;
              for (var key in pal) { root.style.setProperty(key, pal[key]); }

              // Sun / moon on the header horizon — a celestial body tracing the
              // rule line. Both travel left → right: sun from sunrise to sunset,
              // moon from sunset to sunrise. The sun burns red at dawn/dusk and
              // cools to gold at noon; the moon stays a quiet silver.
              var pos;
              if (isDay) {
                pos = ((hour - sunrise) / (sunset - sunrise)) * 100;
              } else {
                var ss = hour >= sunset ? hour - sunset : hour + (24 - sunset);
                var nl = 24 - (sunset - sunrise);
                pos = (ss / nl) * 100;
              }
              root.style.setProperty('--sun-pos', pos.toFixed(2) + '%');
              var celestial;
              if (isDay) {
                celestial = lerp(pal['--canvas-color'], '#c83c2a', warm * 0.6);
              } else {
                celestial = '#a8adb5';
              }
              root.style.setProperty('--celestial-color', celestial);
              root.dataset.celestial = isDay ? 'sun' : 'moon';
              root.dataset.circadian = 'true';

              // Moon phase — the terminator is modelled as a second circle
              // (pseudo-element) sliding across the disc. New moon: shadow
              // circle centred → covers everything. Full: offset = diameter →
              // no overlap → fully lit. Waxing: lit on the right (shadow slides
              // left). Waning: lit on the left (shadow slides right). The
              // intersection of two equal circles gives a curved terminator.
              var MOON_EPOCH = Date.UTC(2000, 0, 6, 18, 14);
              var SYNODIC = 29.530588853;
              var dn = (d.getTime() - MOON_EPOCH) / 86400000;
              var phase = (dn % SYNODIC) / SYNODIC;
              if (phase < 0) phase += 1;
              var illum = (1 - Math.cos(2 * Math.PI * phase)) / 2;
              var waxing = phase < 0.5;
              var moonOff = 8 * illum; /* 0 at new, 8 (diameter) at full */
              root.style.setProperty('--moon-offset', (waxing ? -moonOff : moonOff).toFixed(2) + 'px');
              root.style.setProperty('--moon-glow', Math.round(illum * 70) + '%');
            }

            calc();
            // Recalculate every minute so the palette and celestial drift with
            // the real time — no reload needed to cross sunrise/sunset.
            var timer = setInterval(calc, 60000);
            document.addEventListener('visibilitychange', function () {
              if (!document.hidden) { calc(); clearInterval(timer); timer = setInterval(calc, 60000); }
            });
          } catch (e) {}
        })();
      </script>
    )}
   </head>
  <body>
    <a href="#main" class="skip-link">{t.common.skipToContent}</a>
    {!stillSurface && <ThemeBackground theme={bg} color={canvasColor} />}
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

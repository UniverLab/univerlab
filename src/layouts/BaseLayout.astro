---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeBackground from '../components/ThemeBackground.astro';
import type { BgTheme } from '../lib/experiments';
import { getLang, useTranslations } from '../i18n';
import '../styles/global.css';
import '../styles/surfaces.css';

interface Props {
  title: string;
  description?: string;
  bg?: BgTheme;
  bgColor?: string;
  /** Core pages: shift the palette progressively with the time of day. */
  circadian?: boolean;
  /** Docs: render the background animation in a neutral grey, not the accent. */
  mutedCanvas?: boolean;
  /** Experiment pages: a fixed visual surface (paper, tui, blueprint, …). */
  surface?: string;
  /** Extra JSON-LD for this page (e.g. SoftwareApplication, WebSite), emitted
   *  alongside the site-wide Organization graph. */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  /** Hidden pages: prevent indexing by search engines. */
  noindex?: boolean;
}
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const {
  title,
  description = t.meta.description,
  bg = 'cosmic',
  bgColor,
  circadian = false,
  mutedCanvas = false,
  surface,
  structuredData,
  noindex = false,
} = Astro.props;
const canvasColor = circadian ? (mutedCanvas ? 'auto-mute' : 'auto') : bgColor;
// Surfaces that drop the ambient canvas: paper (a typeset page stays still),
// studio (a lit stage, not drift), and blueprint (cadspec's clean plan — calm
// and geometric, no animation). ghscaff (scaffold) keeps its live drawing.
const stillSurface = ['paper', 'studio', 'blueprint', 'quorum'].includes(surface ?? '');
const colorScheme = ['paper', 'blueprint', 'studio', 'quorum'].includes(surface ?? '') ? 'light' : 'dark';

// Only request the font families a given surface actually uses. Every page
// needs Inter (body) + the mono signature; `paper` adds Spectral; the grotesque
// surfaces add Space Grotesk; terminal surfaces (tui/vcs) and the core pages
// need nothing more. This keeps unused webfonts off the page entirely.
const fontFamilies = ['IBM+Plex+Mono:wght@400;500', 'Inter:wght@400;500;600'];
if (surface === 'paper') {
  fontFamilies.push('Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500');
}
if (['scaffold', 'blueprint', 'observatory', 'studio', 'quorum'].includes(surface ?? '')) {
  fontFamilies.push('Space+Grotesk:wght@300;400;500;600');
}
const fontHref =
  'https://fonts.googleapis.com/css2?' +
  fontFamilies.map((f) => 'family=' + f).join('&') +
  '&display=swap';

const site = Astro.site ?? new URL('https://univerlab.org');
const path = Astro.url.pathname;
const canonical = new URL(path, site).href;
const ogImage = new URL('/og.png', site).href;
// hreflang alternates — only for localized pages (docs are English-only).
const isDocs = path.includes('/docs');
const stripped = path.replace(/^\/es(?=\/|$)/, '') || '/';
const enHref = new URL(stripped, site).href;
const esHref = new URL('/es' + (stripped === '/' ? '' : stripped), site).href;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'UniverLab',
  url: site.href,
  logo: new URL('/favicon.svg', site).href,
  description: t.meta.description,
  sameAs: ['https://github.com/UniverLab'],
};
---
<!doctype html>
<html lang={lang} data-surface={surface}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="color-scheme" content={colorScheme} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fbfbfa" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0f1115" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <!-- Type. IBM Plex Mono is the constant UniverLab signature (the mono
         labels); Inter is the default body. Per-surface display voices:
         Spectral (paper/texforge — typeset serif), Space Grotesk (scaffold,
         blueprint, observatory, studio — technical grotesque), and the mono
         itself for the terminal surfaces (tui/canopy, vcs/gitkit). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking: fetch as `print`, promote to `all` once loaded;
         `display=swap` shows fallback text immediately. -->
    <link rel="stylesheet" href={fontHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontHref} /></noscript>
    {/* Experiment banners are block ASCII tuned to DejaVu Sans Mono (see Banner.astro). */}
    {surface && (
      <link rel="preload" href="/fonts/DejaVuSansMono.ttf" as="font" type="font/ttf" crossorigin />
    )}
    {!isDocs && (
      <>
        <link rel="alternate" hreflang="en" href={enHref} />
        <link rel="alternate" hreflang="es" href={esHref} />
        <link rel="alternate" hreflang="x-default" href={enHref} />
      </>
    )}
    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="UniverLab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {structuredData &&
      (Array.isArray(structuredData) ? structuredData : [structuredData]).map((d) => (
        <script type="application/ld+json" set:html={JSON.stringify(d)} />
      ))}
    <!-- Pre-paint language detection: first-time visitors whose system is in
         Spanish are sent to /es once; an explicit choice is always respected. -->
    <script is:inline>
      (function () {
        try {
          var path = location.pathname;
          // Documentation is English-only and has no /es mirror — never redirect it.
          if (path.indexOf('/docs') !== -1) return;
          var stored = localStorage.getItem('univerlab-lang');
          var onEs = path === '/es' || path.indexOf('/es/') === 0;
          if (!stored) {
            var sys = (navigator.language || 'en').toLowerCase().slice(0, 2);
            if (sys === 'es' && !onEs) {
              localStorage.setItem('univerlab-lang', 'es');
              location.replace('/es' + (path === '/' ? '' : path));
              return;
            }
          } else if (stored === 'es' && !onEs) {
            location.replace('/es' + (path === '/' ? '' : path));
          } else if (stored === 'en' && onEs) {
            location.replace(path.replace(/^\/es/, '') || '/');
          }
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      // Console Easter egg — ASCII art + invitation to contribute.
      (function () {
        var art = `
        _..._
      .'     '.      _
     /    .-""-\\   _/ \\
   .-|   /:.   |  |   |
   |  \\  |:.   /.-'-./
   | .-'-;:__.'    =/
   .'=  *=|     _.='
  /   _.  |    ;
 ;-.-'|    \\   |
/   | \\    _\\  _\\
\\__/'._;.  ==' ==\\
         \\    \\   |
         /    /   /
         /-._/-._/
         \\   \`\\  \\
          \`-._/._/

Open Computational Laboratory
https://github.com/UniverLab

 "The next great discovery is one pull request."`;
        console.log(art);
      })();
    </script>
    <script is:inline>
      // Celestial position — always runs so the sun/moon dot moves along the
      // header rule on every page. Circadian pages add palette + color on top.
      (function () {
        function calc() {
          var d = new Date();
          var hour = d.getHours() + d.getMinutes() / 60;
          var y = d.getFullYear();
          var kJan = new Date(y, 0, 1).getTimezoneOffset();
          var kJul = new Date(y, 6, 1).getTimezoneOffset();
          var half = 6;
          if (kJan !== kJul) {
            var southern = kJan < kJul;
            var doy = Math.floor((d - new Date(y, 0, 0)) / 86400000);
            var s = Math.cos((2 * Math.PI * (doy - 172)) / 365.25);
            if (southern) s = -s;
            half = 6 + 2.5 * s;
          }
          var sunrise = 12 - half;
          var sunset = 12 + half;
          var isDay = hour >= sunrise && hour < sunset;
          var pos;
          if (isDay) {
            pos = ((hour - sunrise) / (sunset - sunrise)) * 100;
          } else {
            var ss = hour >= sunset ? hour - sunset : hour + (24 - sunset);
            var nl = 24 - (sunset - sunrise);
            pos = (ss / nl) * 100;
          }
          document.documentElement.style.setProperty('--sun-pos', pos.toFixed(2) + '%');
          document.documentElement.dataset.celestial = isDay ? 'sun' : 'moon';
        }
        calc();
        setInterval(calc, 60000);
        document.addEventListener('visibilitychange', function () {
          if (!document.hidden) calc();
        });
      })();
    </script>
    {circadian && (
      <script is:inline>
        // Circadian palette. Polarity (light by day, dark by night) NEVER
        // interpolates across — that mid-point is grey mush with no contrast.
        // Instead: day = always light (dark ink), night = always dark (light
        // ink); within each we only interpolate WARMTH, so dawn/dusk are the warm
        // ends. The light↔dark flip is the sunrise/sunset, estimated for the
        // visitor's latitude & season (see below). Pre-paint, so no flash.
        // Both the landing and the docs are circadian.
        (function () {
          try {
            var DAY_COOL = { '--bg': '#fbfbfa', '--bg-raise': '#f1f1ee', '--ink': '#1a1c1e', '--ink-dim': '#555a61', '--ink-faint': '#8b9099', '--line': '#e4e2dc', '--accent': '#9a7b16', '--canvas-color': '#b59a3a', '--canvas-mute': '#b3b4ae' };
            var DAY_WARM = { '--bg': '#f7efe4', '--bg-raise': '#efe5d6', '--ink': '#241f18', '--ink-dim': '#5f574b', '--ink-faint': '#948975', '--line': '#e6dac6', '--accent': '#b5791f', '--canvas-color': '#cf9a3a', '--canvas-mute': '#bdb5a6' };
            var NIGHT_WARM = { '--bg': '#1a1822', '--bg-raise': '#221f2b', '--ink': '#ece3d6', '--ink-dim': '#b0a596', '--ink-faint': '#756b5f', '--line': '#2e2a36', '--accent': '#e8a24a', '--canvas-color': '#e0a24a', '--canvas-mute': '#565160' };
            var NIGHT_COOL = { '--bg': '#0f1115', '--bg-raise': '#15181d', '--ink': '#e3e6e8', '--ink-dim': '#a8adb5', '--ink-faint': '#6b7178', '--line': '#23262c', '--accent': '#e6c84a', '--canvas-color': '#d3bf72', '--canvas-mute': '#474a54' };

            function hx(c) { return [parseInt(c.slice(1, 3), 16), parseInt(c.slice(3, 5), 16), parseInt(c.slice(5, 7), 16)]; }
            function lerp(c1, c2, t) {
              var x = hx(c1), y = hx(c2);
              function h2(n) { return ('0' + Math.round(n).toString(16)).slice(-2); }
              return '#' + h2(x[0] + (y[0] - x[0]) * t) + h2(x[1] + (y[1] - x[1]) * t) + h2(x[2] + (y[2] - x[2]) * t);
            }
            function mix(a, b, f) { var o = {}; for (var k in a) o[k] = lerp(a[k], b[k], f); return o; }

            function applyPalette(pal) {
              var root = document.documentElement;
              for (var key in pal) { root.style.setProperty(key, pal[key]); }
            }

            function calc() {
              var d = new Date();
              var hour = d.getHours() + d.getMinutes() / 60;
              var y = d.getFullYear();
              var kJan = new Date(y, 0, 1).getTimezoneOffset();
              var kJul = new Date(y, 6, 1).getTimezoneOffset();
              var half = 6;
              if (kJan !== kJul) {
                var southern = kJan < kJul;
                var doy = Math.floor((d - new Date(y, 0, 0)) / 86400000);
                var s = Math.cos((2 * Math.PI * (doy - 172)) / 365.25);
                if (southern) s = -s;
                half = 6 + 2.5 * s;
              }
              var sunrise = 12 - half;
              var sunset = 12 + half;
              var isDay = hour >= sunrise && hour < sunset;
              var pal;
              if (isDay) {
                var t = (hour - sunrise) / (sunset - sunrise);
                var warm = Math.abs(t - 0.5) * 2;
                pal = mix(DAY_COOL, DAY_WARM, warm);
              } else {
                var sinceSunset = hour >= sunset ? hour - sunset : hour + (24 - sunset);
                var nightLen = 24 - (sunset - sunrise);
                var g = nightLen > 0 ? sinceSunset / nightLen : 0;
                pal = mix(NIGHT_WARM, NIGHT_COOL, Math.min(g * 2, 1));
              }
              applyPalette(pal);

              var pos;
              if (isDay) {
                pos = ((hour - sunrise) / (sunset - sunrise)) * 100;
              } else {
                var ss = hour >= sunset ? hour - sunset : hour + (24 - sunset);
                var nl = 24 - (sunset - sunrise);
                pos = (ss / nl) * 100;
              }
              var root = document.documentElement;
              root.style.setProperty('--sun-pos', pos.toFixed(2) + '%');
              var celestial;
              if (isDay) {
                celestial = lerp(pal['--canvas-color'], '#c83c2a', warm * 0.6);
              } else {
                celestial = '#a8adb5';
              }
              root.style.setProperty('--celestial-color', celestial);
              root.dataset.celestial = isDay ? 'sun' : 'moon';
              root.dataset.circadian = 'true';

              var MOON_EPOCH = Date.UTC(2000, 0, 6, 18, 14);
              var SYNODIC = 29.530588853;
              var dn = (d.getTime() - MOON_EPOCH) / 86400000;
              var phase = (dn % SYNODIC) / SYNODIC;
              if (phase < 0) phase += 1;
              var illum = (1 - Math.cos(2 * Math.PI * phase)) / 2;
              var waxing = phase < 0.5;
              var moonOff = 8 * illum;
              root.style.setProperty('--moon-offset', (waxing ? -moonOff : moonOff).toFixed(2) + 'px');
              root.style.setProperty('--moon-glow', Math.round(illum * 70) + '%');
            }

            // Expose applyTheme globally so the command palette can override.
            window.applyTheme = function (mode) {
              if (mode === 'day') {
                applyPalette(DAY_COOL);
                document.documentElement.dataset.celestial = 'sun';
              } else if (mode === 'night') {
                applyPalette(NIGHT_COOL);
                document.documentElement.dataset.celestial = 'moon';
              } else {
                calc();
              }
            };

            var saved = localStorage.getItem('univerlab-theme');
            if (saved === 'day') { applyPalette(DAY_COOL); document.documentElement.dataset.celestial = 'sun'; document.documentElement.dataset.circadian = 'true'; }
            else if (saved === 'night') { applyPalette(NIGHT_COOL); document.documentElement.dataset.celestial = 'moon'; document.documentElement.dataset.circadian = 'true'; }
            else { calc(); }

            var timer = setInterval(calc, 60000);
            document.addEventListener('visibilitychange', function () {
              if (!document.hidden && !localStorage.getItem('univerlab-theme')) { calc(); clearInterval(timer); timer = setInterval(calc, 60000); }
            });
          } catch (e) {}
        })();
      </script>
    )}
   </head>
  <body>
    <a href="#main" class="skip-link">{t.common.skipToContent}</a>
    {!stillSurface && <ThemeBackground theme={bg} color={canvasColor} />}
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Command palette — terminal-style / command with Tab autocomplete.
      // Commands are derived from experiment IDs + static routes.
      // To add a new experiment: add its ID to the experiments array in
      // experiments.ts — the palette picks it up automatically.
      (function () {
        var lang = document.documentElement.lang === 'es' ? 'es' : 'en';
        var base = lang === 'es' ? '/es' : '';
        var path = window.location.pathname;

        // /find — open a search overlay for the current page / docs.
        function openFind() {
          var existing = document.querySelector('.find-overlay');
          if (existing) { existing.remove(); return; }
          var overlay = document.createElement('div');
          overlay.className = 'find-overlay';
          overlay.innerHTML = '<div class="find-bar">' +
            '<input type="text" class="find-input" placeholder="Find..." autofocus />' +
            '<span class="find-count"></span>' +
            '<button class="find-prev" type="button" aria-label="Previous">&#9650;</button>' +
            '<button class="find-next" type="button" aria-label="Next">&#9660;</button>' +
            '<button class="find-close" type="button" aria-label="Close">&times;</button>' +
            '</div>';
          document.body.appendChild(overlay);
          var input = overlay.querySelector('.find-input');
          var count = overlay.querySelector('.find-count');
          var highlights = [];
          var current = -1;

          function clearHighlights() {
            highlights.forEach(function (h) {
              var parent = h.parentNode;
              if (parent) { parent.replaceChild(document.createTextNode(h.textContent), h); parent.normalize(); }
            });
            highlights = [];
            current = -1;
          }

          function highlightAll(query) {
            clearHighlights();
            if (!query) { count.textContent = ''; return; }
            var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
              acceptNode: function (n) {
                if (n.parentElement && (n.parentElement.closest('.find-overlay') || n.parentElement.closest('script') || n.parentElement.closest('style'))) return NodeFilter.FILTER_REJECT;
                return NodeFilter.FILTER_ACCEPT;
              }
            });
            var nodes = [];
            while (walker.nextNode()) nodes.push(walker.currentNode);
            var lower = query.toLowerCase();
            nodes.forEach(function (node) {
              var text = node.textContent;
              var lowerText = text.toLowerCase();
              var idx = lowerText.indexOf(lower);
              if (idx === -1) return;
              var frag = document.createDocumentFragment();
              var last = 0;
              while (idx !== -1) {
                frag.appendChild(document.createTextNode(text.slice(last, idx)));
                var span = document.createElement('mark');
                span.className = 'find-hl';
                span.textContent = text.slice(idx, idx + query.length);
                frag.appendChild(span);
                highlights.push(span);
                last = idx + query.length;
                idx = lowerText.indexOf(lower, last);
              }
              frag.appendChild(document.createTextNode(text.slice(last)));
              node.parentNode.replaceChild(frag, node);
            });
            count.textContent = highlights.length ? '1/' + highlights.length : '0 results';
            if (highlights.length) scrollToHighlight(0);
          }

          function scrollToHighlight(idx) {
            if (!highlights.length) return;
            highlights.forEach(function (h) { h.classList.remove('find-active'); });
            current = ((idx % highlights.length) + highlights.length) % highlights.length;
            highlights[current].classList.add('find-active');
            highlights[current].scrollIntoView({ block: 'center' });
            count.textContent = (current + 1) + '/' + highlights.length;
          }

          var debounce = null;
          input.addEventListener('input', function () {
            clearTimeout(debounce);
            debounce = setTimeout(function () { highlightAll(input.value); }, 200);
          });
          overlay.querySelector('.find-next').addEventListener('click', function () { scrollToHighlight(current + 1); });
          overlay.querySelector('.find-prev').addEventListener('click', function () { scrollToHighlight(current - 1); });
          overlay.querySelector('.find-close').addEventListener('click', function () { clearHighlights(); overlay.remove(); });
          input.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { clearHighlights(); overlay.remove(); }
            if (e.key === 'Enter') { e.preventDefault(); scrollToHighlight(e.shiftKey ? current - 1 : current + 1); }
          });
          setTimeout(function () { input.focus(); }, 50);
        }

        // /theme submenu — replaces the command list with theme options.
        function showThemeMenu() {
          inSubmenu = true;
          var themeCmds = [
            { cmd: 'day', label: 'Light', action: function () { localStorage.setItem('univerlab-theme', 'day'); applyTheme('day'); } },
            { cmd: 'night', label: 'Dark', action: function () { localStorage.setItem('univerlab-theme', 'night'); applyTheme('night'); } },
            { cmd: 'circadian', label: 'Auto (circadian)', action: function () { localStorage.removeItem('univerlab-theme'); applyTheme('circadian'); } },
          ];
          filtered = themeCmds;
          selected = 0;
          input.value = '/theme ';
          open();
          render();
        }

        // Static commands — always available.
        var staticCmds = [
          { cmd: '/home', label: 'Home', href: base + '/' },
          { cmd: '/experiments', label: 'Experiments', href: base + '/experiments' },
          { cmd: '/manifesto', label: 'Manifesto', href: base + '/manifesto' },
          { cmd: '/contributors', label: 'Contributors', href: base + '/contributors' },
          { cmd: '/github', label: 'GitHub', action: function () { window.open(githubUrl(), '_blank', 'noopener'); } },
          { cmd: '/find', label: 'Find on page', action: function () { openFind(); } },
          { cmd: '/theme', label: 'Theme…', action: function () { showThemeMenu(); } },
          { cmd: '/archive', label: 'The Archive', href: base + '/archive' },
        ];

        // Experiment IDs — auto-generated from the registry.
        // Keep this list in sync with experiments.ts (add new IDs here).
        var experimentIds = ['canopy', 'texforge', 'gitkit', 'ghscaff', 'cadspec', 'astro-denoise', 'demostage', 'quorum'];
        var experimentGithub = {
          canopy: 'https://github.com/UniverLab/harness-canopy',
          texforge: 'https://github.com/UniverLab/texforge',
          gitkit: 'https://github.com/UniverLab/gitkit',
          ghscaff: 'https://github.com/UniverLab/ghscaff',
          cadspec: 'https://github.com/UniverLab/cadspec',
          'astro-denoise': 'https://github.com/UniverLab',
          demostage: 'https://github.com/UniverLab/demostage',
          quorum: 'https://github.com/UniverLab/quorum',
        };
        function currentExpId() {
          var m = window.location.pathname.match(/\/(?:es\/)?(\w[\w-]*)\/?$/);
          return m && experimentIds.indexOf(m[1]) !== -1 ? m[1] : null;
        }
        function githubUrl() {
          var id = currentExpId();
          return id && experimentGithub[id] ? experimentGithub[id] : 'https://github.com/UniverLab';
        }
        var experimentCmds = experimentIds.map(function (id) {
          return { cmd: '/' + id, label: id, href: base + '/' + id };
        });

        // /docs — only on experiment pages.
        var docMatch = path.match(/\/(?:es\/)?(\w[\w-]*)\/?$/);
        var currentExp = docMatch && experimentIds.indexOf(docMatch[1]) !== -1 ? docMatch[1] : null;
        var allCmds = staticCmds.concat(experimentCmds);
        if (currentExp) {
          allCmds.unshift({ cmd: '/docs', label: 'Docs (' + currentExp + ')', href: '/' + currentExp + '/docs' });
        }

        var overlay = null;
        var input = null;
        var overlay = null;
        var list = null;
        var selected = 0;
        var filtered = [];
        var inSubmenu = false;

        function create() {
          overlay = document.createElement('div');
          overlay.id = 'cmd-palette';
          overlay.innerHTML =
            '<div class="cmd-palette-inner">' +
              '<div class="cmd-input-row">' +
                '<span class="cmd-prefix">/</span>' +
                '<input class="cmd-input" type="text" spellcheck="false" autocomplete="off" placeholder="Type a command..." />' +
              '</div>' +
              '<ul class="cmd-list"></ul>' +
            '</div>';
          document.body.appendChild(overlay);
          input = overlay.querySelector('.cmd-input');
          list = overlay.querySelector('.cmd-list');
          input.addEventListener('input', onInput);
          input.addEventListener('keydown', onKey);
          overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
          filter('');
        }

        function open() {
          if (!overlay) create();
          overlay.classList.add('open');
          input.value = '';
          selected = 0;
          filter('');
          setTimeout(function () { input.focus(); }, 50);
        }

        function close() {
          if (overlay) overlay.classList.remove('open');
          inSubmenu = false;
        }

        function isOpen() { return overlay && overlay.classList.contains('open'); }

        function filter(q) {
          q = q.toLowerCase().replace(/^\//, '');
          if (inSubmenu) {
            // In submenu: filter the theme options, not all commands.
            var themeCmds = [
              { cmd: 'day', label: 'Light', action: function () { localStorage.setItem('univerlab-theme', 'day'); applyTheme('day'); } },
              { cmd: 'night', label: 'Dark', action: function () { localStorage.setItem('univerlab-theme', 'night'); applyTheme('night'); } },
              { cmd: 'circadian', label: 'Auto (circadian)', action: function () { localStorage.removeItem('univerlab-theme'); applyTheme('circadian'); } },
            ];
            filtered = q
              ? themeCmds.filter(function (c) { return c.cmd.toLowerCase().indexOf(q) !== -1 || c.label.toLowerCase().indexOf(q) !== -1; })
              : themeCmds;
          } else {
            filtered = q
              ? allCmds.filter(function (c) { return c.cmd.toLowerCase().indexOf(q) !== -1 || c.label.toLowerCase().indexOf(q) !== -1; })
              : allCmds.slice();
          }
          selected = 0;
          render();
        }

        function render() {
          list.innerHTML = filtered.map(function (c, i) {
            return '<li class="cmd-item' + (i === selected ? ' sel' : '') + '">' +
              '<span class="cmd-cmd">' + c.cmd + '</span>' +
              '<span class="cmd-label">' + c.label + '</span>' +
            '</li>';
          }).join('');
          // Scroll selected into view.
          var sel = list.querySelector('.sel');
          if (sel) sel.scrollIntoView({ block: 'nearest' });
        }

        function execute(cmd) {
          close();
          if (cmd.action) {
            cmd.action();
          } else if (cmd.href.startsWith('http')) {
            window.open(cmd.href, '_blank', 'noopener');
          } else {
            window.location.href = cmd.href;
          }
        }

        function onInput() {
          var v = input.value;
          // Keep the / prefix.
          if (!v.startsWith('/')) input.value = '/' + v;
          filter(input.value);
        }

        function onKey(e) {
          if (e.key === 'Escape') { e.preventDefault(); close(); return; }
          if (e.key === 'ArrowDown') { e.preventDefault(); selected = Math.min(selected + 1, filtered.length - 1); render(); return; }
          if (e.key === 'ArrowUp') { e.preventDefault(); selected = Math.max(selected - 1, 0); render(); return; }
          if (e.key === 'Tab') {
            e.preventDefault();
            if (filtered[selected]) {
              input.value = filtered[selected].cmd;
              filter(input.value);
            }
            return;
          }
          if (e.key === 'Enter') {
            e.preventDefault();
            if (filtered[selected]) execute(filtered[selected]);
            return;
          }
        }

        // Global keyboard shortcuts.
        var expFocusIndex = -1;
        var keySeq = '';
        document.addEventListener('keydown', function (e) {
          if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

          // Easter egg: typing "42" shows the Answer.
          keySeq += e.key;
          if (keySeq.length > 10) keySeq = keySeq.slice(-10);
          if (keySeq.indexOf('42') !== -1) {
            keySeq = '';
            var msg = document.createElement('div');
            msg.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(18,18,22,0.92);color:#fff;font-family:"IBM Plex Mono",monospace;font-size:0.9rem;padding:0.8rem 1.4rem;border-radius:8px;border:1px solid #fff;box-shadow:0 8px 32px rgba(0,0,0,0.5),0 0 20px rgba(255,255,255,0.15);z-index:320;text-align:center;max-width:90vw;';
            var lang = document.documentElement.lang || 'en';
            var html = lang === 'es'
              ? '<span style="color:#ffe264">42</span> — La <span style="color:#ffe264">Respuesta</span> a la Pregunta Fundamental de la <span style="color:#ffe264">Vida</span>, el <span style="color:#ffe264">Universo</span> y Todo lo <span style="color:#ffe264">Demás</span>.'
              : '<span style="color:#ffe264">42</span> — The <span style="color:#ffe264">Answer</span> to the Ultimate Question of Life, the <span style="color:#ffe264">Universe</span>, and <span style="color:#ffe264">Everything</span>.';
            msg.innerHTML = html;
            document.body.appendChild(msg);
            setTimeout(function () { msg.style.transition = 'opacity 0.5s'; msg.style.opacity = '0'; setTimeout(function () { msg.remove(); }, 500); }, 5000);
            return;
          }

          // / → open command palette
          if (e.key === '/') {
            e.preventDefault();
            if (isOpen()) close(); else open();
            return;
          }

          // ? → open help / command list
          if (e.key === '?') {
            e.preventDefault();
            if (isOpen()) { close(); return; }
            open();
            return;
          }

          // Esc → close palette or go back
          if (e.key === 'Escape') {
            if (isOpen()) { e.preventDefault(); close(); return; }
            return;
          }

          // Don't handle navigation shortcuts when palette is open.
          if (isOpen()) return;

          // Single-key navigation (when not in an input).
          var lang2 = document.documentElement.lang === 'es' ? 'es' : 'en';
          var base2 = lang2 === 'es' ? '/es' : '';
          var navMap = {
            h: function () { return base2 + '/'; },
            e: function () { return base2 + '/experiments'; },
            m: function () { return base2 + '/manifesto'; },
            c: function () { return base2 + '/contributors'; },
            g: function () { return githubUrl(); },
          };
          var navEntry = navMap[e.key];
          if (navEntry) {
            e.preventDefault();
            var dst = navEntry();
            if (dst.startsWith('http')) window.open(dst, '_blank', 'noopener');
            else window.location.href = dst;
            return;
          }

          // i → scroll to top and open celestial fact popup
          if (e.key === 'i') {
            e.preventDefault();
            if (window.scrollY < 10) {
              var btn = document.querySelector('.celestial-btn');
              if (btn) btn.click();
            } else {
              window.scrollTo({ top: 0, behavior: 'smooth' });
              // Wait for scroll to fully stop before opening (the popup's own
              // scroll-listener closes it if it fires during a scroll).
              var scrollTimer = null;
              var onScroll = function () {
                clearTimeout(scrollTimer);
                scrollTimer = setTimeout(function () {
                  window.removeEventListener('scroll', onScroll);
                  if (window.scrollY < 10) {
                    var btn2 = document.querySelector('.celestial-btn');
                    if (btn2) btn2.click();
                  }
                }, 150);
              };
              window.addEventListener('scroll', onScroll, { passive: true });
            }
            return;
          }

          // f → open find overlay
          if (e.key === 'f') {
            e.preventDefault();
            openFind();
            return;
          }

          // Shift+Left → go back, Shift+Right → go forward (browser history)
          if (e.shiftKey && e.key === 'ArrowLeft') {
            e.preventDefault();
            history.back();
            return;
          }
          if (e.shiftKey && e.key === 'ArrowRight') {
            e.preventDefault();
            history.forward();
            return;
          }

          // Shift+ArrowUp / Shift+ArrowDown → prev / next experiment, doc, or card focus
          if (e.shiftKey && (e.key === 'ArrowUp' || e.key === 'ArrowDown')) {
            // Experiment detail pages: use exp-nav-link
            var expNavLinks = document.querySelectorAll('a.exp-nav-link');
            if (expNavLinks.length) {
              e.preventDefault();
              var idx = e.key === 'ArrowDown' ? 1 : 0;
              if (expNavLinks[idx]) window.location.href = expNavLinks[idx].getAttribute('href') || '/';
              return;
            }
            // Docs pages: use sidebar nav
            var docItems = document.querySelectorAll('.docs nav .item');
            if (docItems.length > 1) {
              e.preventDefault();
              var curDoc = -1;
              for (var d = 0; d < docItems.length; d++) {
                if (docItems[d].classList.contains('active')) { curDoc = d; break; }
              }
              var nextDoc = e.key === 'ArrowDown'
                ? (curDoc < docItems.length - 1 ? curDoc + 1 : 0)
                : (curDoc > 0 ? curDoc - 1 : docItems.length - 1);
              window.location.href = docItems[nextDoc].getAttribute('href') || '/';
              return;
            }
            // Listing pages (home, experiments): focus cards
            var cards = document.querySelectorAll('a.card, a.row');
            if (cards.length > 1) {
              e.preventDefault();
              if (expFocusIndex === -1) expFocusIndex = e.key === 'ArrowDown' ? 0 : cards.length - 1;
              else expFocusIndex = e.key === 'ArrowDown'
                ? (expFocusIndex + 1) % cards.length
                : (expFocusIndex - 1 + cards.length) % cards.length;
              var card = cards[expFocusIndex];
              card.focus({ preventScroll: true });
              card.scrollIntoView({ block: 'nearest' });
              return;
            }
            return;
          }

          // ArrowUp / ArrowDown → jump between sections and cards on the page
          if (e.key === 'ArrowUp' || e.key === 'ArrowDown') {
            var targets = [];
            document.querySelectorAll('section, a.card, a.row, .prose-doc h2').forEach(function (el) {
              targets.push({ el: el, top: el.offsetTop });
            });
            targets.sort(function (a, b) { return a.top - b.top; });
            if (targets.length > 1) {
              e.preventDefault();
              var scrollY = window.scrollY;
              var found = -1;
              for (var i = 0; i < targets.length; i++) {
                if (e.key === 'ArrowDown') {
                  if (targets[i].top > scrollY + 4) { found = i; break; }
                } else {
                  if (targets[i].top < scrollY - 4) { found = i; break; }
                }
              }
              if (found === -1) found = e.key === 'ArrowDown' ? targets.length - 1 : 0;
              targets[found].el.scrollIntoView({ block: 'start' });
              return;
            }
          }

          // Enter → follow the focused card link (if palette is closed)
          if (e.key === 'Enter' && !isOpen() && expFocusIndex !== -1) {
            var focused = document.activeElement;
            if (focused && focused.matches('a.card, a.row') && focused.hasAttribute('href')) {
              e.preventDefault();
              window.location.href = focused.getAttribute('href') || '/';
            }
          }
        });
      })();
    </script>
    <style is:global>
      /* Command palette — terminal-style, always dark, grey monospace. */
      #cmd-palette {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 300;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(6px);
        align-items: flex-start;
        justify-content: center;
        padding-top: 20vh;
      }
      #cmd-palette.open { display: flex; }
      .cmd-palette-inner {
        width: 28rem;
        max-width: 92vw;
        background: rgba(18, 18, 22, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
        overflow: hidden;
        font-family: 'IBM Plex Mono', monospace;
      }
      .cmd-input-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8rem 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }
      .cmd-prefix {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.9rem;
        user-select: none;
      }
      .cmd-input {
        flex: 1;
        background: transparent;
        border: 0;
        outline: none;
        color: #e0e0e0;
        font-family: inherit;
        font-size: 0.9rem;
        caret-color: rgba(255, 255, 255, 0.4);
      }
      .cmd-input::placeholder { color: rgba(255, 255, 255, 0.2); }
      .cmd-list {
        list-style: none;
        margin: 0;
        padding: 0.3rem 0;
        max-height: 20rem;
        overflow-y: auto;
      }
      .cmd-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 1rem;
        cursor: pointer;
        transition: background 0.1s;
      }
      .cmd-item:hover, .cmd-item.sel {
        background: rgba(255, 255, 255, 0.06);
      }
      .cmd-cmd {
        color: #e0e0e0;
        font-size: 0.85rem;
      }
      .cmd-label {
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.75rem;
      }
      .cmd-list::-webkit-scrollbar { width: 4px; }
      .cmd-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

      /* Find overlay */
      .find-overlay {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 310;
        display: flex;
        justify-content: center;
        padding-top: 0.75rem;
        pointer-events: none;
      }
      .find-bar {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(18, 18, 22, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 0.4rem 0.6rem;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        pointer-events: auto;
        font-family: 'IBM Plex Mono', monospace;
      }
      .find-input {
        background: none;
        border: none;
        color: #e0e0e0;
        font-family: inherit;
        font-size: 0.85rem;
        width: 18rem;
        outline: none;
      }
      .find-input::placeholder { color: rgba(255,255,255,0.3); }
      .find-count { color: rgba(255,255,255,0.35); font-size: 0.75rem; min-width: 3.5rem; text-align: center; }
      .find-prev, .find-next, .find-close {
        background: none;
        border: none;
        color: rgba(255,255,255,0.4);
        cursor: pointer;
        font-size: 0.85rem;
        padding: 0.15rem 0.3rem;
        border-radius: 3px;
      }
      .find-prev:hover, .find-next:hover { color: #e0e0e0; background: rgba(255,255,255,0.08); }
      .find-close { font-size: 1rem; }
      .find-close:hover { color: #e0e0e0; }
      .find-hl { background: rgba(230, 200, 74, 0.3); border-radius: 2px; }
      .find-hl.find-active { background: rgba(230, 200, 74, 0.6); }
    </style>
  </body>
</html>

---
import BaseLayout from './BaseLayout.astro';
import { byId } from '../lib/experiments';
import { getLang, useTranslations } from '../i18n';

interface DocLink { slug: string; title: string; }
interface Props {
  id: string;
  title: string;
  description?: string;
  links: DocLink[];
  current: string;
}
const { id, title, description, links, current } = Astro.props;
const exp = byId(id);
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const base = `/${id}/docs`;
---
<BaseLayout title={`${title} · ${exp.name} docs`} description={description} bg="drift" bgColor={exp.essenceHex}>
  <div class="wrap docs" style={`--essence: ${exp.essenceHex}`}>
    <aside>
      <a class="back label" href={`/${id}`}>← {exp.name}</a>
      <span class="label head">{t.common.docsHome}</span>
      <nav>
        {links.map((l) => (
          <a
            href={l.slug ? `${base}/${l.slug}` : base}
            class:list={['item', { active: l.slug === current }]}
          >{l.title}</a>
        ))}
      </nav>
    </aside>
    <article class="prose-doc">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 15rem 1fr;
    gap: 3rem;
    padding-block: 2.5rem 5rem;
    align-items: start;
  }
  @media (max-width: 52rem) { .docs { grid-template-columns: 1fr; gap: 1.5rem; } }

  aside { position: sticky; top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  @media (max-width: 52rem) { aside { position: static; } }
  .back { text-decoration: none; color: var(--essence); margin-bottom: 0.8rem; }
  .head { color: var(--ink-faint); margin-bottom: 0.3rem; }
  nav { display: flex; flex-direction: column; border-left: 1px solid var(--line); }
  .item {
    text-decoration: none; color: var(--ink-dim); font-size: 0.92rem;
    padding: 0.32rem 0 0.32rem 0.9rem; margin-left: -1px;
    border-left: 1px solid transparent;
  }
  .item:hover { color: var(--ink); }
  .item.active { color: var(--essence); border-left-color: var(--essence); }

  .prose-doc { max-width: 46rem; min-width: 0; }
</style>

<style is:global>
  /* Markdown rendering for repo docs */
  .prose-doc h1 { font-size: 1.9rem; margin: 0 0 1rem; letter-spacing: -0.015em; }
  .prose-doc h2 { font-size: 1.35rem; margin: 2.4rem 0 0.8rem; padding-top: 1.4rem; border-top: 1px solid var(--line); }
  .prose-doc h3 { font-size: 1.08rem; margin: 1.8rem 0 0.6rem; }
  .prose-doc p, .prose-doc li { color: var(--ink-dim); line-height: 1.7; }
  .prose-doc a { color: var(--essence); }
  .prose-doc strong { color: var(--ink); font-weight: 500; }
  .prose-doc ul, .prose-doc ol { padding-left: 1.2rem; }
  .prose-doc li { margin: 0.3rem 0; }
  .prose-doc code {
    font-family: var(--font-mono); font-size: 0.86em;
    background: var(--bg-raise); padding: 0.12em 0.38em; border-radius: 3px; color: var(--essence);
  }
  .prose-doc pre {
    background: var(--bg-raise) !important; border: 1px solid var(--line);
    padding: 1rem 1.1rem; overflow-x: auto; font-size: 0.82rem; line-height: 1.6; border-radius: 4px;
  }
  .prose-doc pre code { background: none; padding: 0; color: inherit; }
  .prose-doc table { width: 100%; border-collapse: collapse; margin: 1.2rem 0; font-size: 0.9rem; }
  .prose-doc th, .prose-doc td { text-align: left; padding: 0.55rem 0.8rem; border: 1px solid var(--line); }
  .prose-doc th { color: var(--ink); font-weight: 500; background: var(--bg-raise); }
  .prose-doc td { color: var(--ink-dim); }
  .prose-doc blockquote {
    border-left: 2px solid var(--essence); margin: 1.2rem 0; padding: 0.2rem 0 0.2rem 1.1rem;
    color: var(--ink-dim); font-style: italic;
  }
  .prose-doc hr { border: 0; border-top: 1px solid var(--line); margin: 2rem 0; }
</style>

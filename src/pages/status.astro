---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Mission Log — UniverLab" description="Real-time activity from UniverLab experiments." bg="cosmic" circadian>
  <section class="wrap log">
    <span class="label">MISSION LOG</span>
    <h1>Status</h1>
    <p class="intro">Real-time activity from UniverLab experiments and tools.</p>
    <div id="log-entries">
      <article class="entry skeleton"><time></time><div class="entry-body"></div></article>
      <article class="entry skeleton"><time></time><div class="entry-body"></div></article>
      <article class="entry skeleton"><time></time><div class="entry-body"></div></article>
    </div>
  </section>

  <style>
    .log {
      max-width: 42rem;
      padding-block: 4rem 6rem;
    }
    .log .label {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-faint);
      display: block;
      margin-bottom: 1.2rem;
    }
    .log h1 {
      font-family: var(--font-mono);
      font-size: 1.6rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--ink);
      margin-bottom: 0.6rem;
    }
    .log .intro {
      color: var(--ink-dim);
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 3rem;
    }
    #log-entries { display: flex; flex-direction: column; }
    .entry {
      display: grid;
      grid-template-columns: 7rem 1fr;
      gap: 1.2rem;
      padding-block: 1.8rem;
      border-bottom: 1px solid var(--line);
      align-items: start;
    }
    .entry time {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--ink-faint);
      padding-top: 0.15rem;
      white-space: nowrap;
    }
    .entry h3 {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      color: var(--accent);
      margin-bottom: 0.3rem;
    }
    .entry p {
      color: var(--ink-faint);
      font-size: 0.88rem;
      line-height: 1.65;
      white-space: pre-line;
    }
    .entry .type-badge {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.58rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-dim);
      border: 1px solid var(--line);
      padding: 0.12rem 0.4rem;
      border-radius: 3px;
      margin-bottom: 0.4rem;
    }

    /* Skeleton */
    .skeleton .entry-body {
      height: 3rem;
      border-radius: 4px;
      background: linear-gradient(90deg, var(--line) 25%, transparent 50%, var(--line) 75%);
      background-size: 200% 100%;
      animation: skeleton-pulse 1.8s ease-in-out infinite;
    }
    .skeleton time {
      height: 0.8rem;
      border-radius: 3px;
      background: linear-gradient(90deg, var(--line) 25%, transparent 50%, var(--line) 75%);
      background-size: 200% 100%;
      animation: skeleton-pulse 1.8s ease-in-out infinite;
      display: block;
    }
    @keyframes skeleton-pulse {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    /* Empty state */
    #log-entries:empty::after {
      content: 'No entries yet. The log is waiting for its first transmission.';
      display: block;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--ink-faint);
      padding-block: 3rem;
      text-align: center;
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      background: var(--bg-raise);
      border: 1px solid var(--accent);
      border-left: 2px solid var(--accent);
      padding: 0.7rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--ink);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
      animation: toast-in 0.2s ease;
      z-index: 50;
      max-width: 22rem;
    }
    @keyframes toast-in {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .toast.fade-out {
      animation: toast-out 0.3s ease forwards;
    }
    @keyframes toast-out {
      from { opacity: 1; }
      to { opacity: 0; transform: translateY(8px); }
    }

    /* Scroll-driven fade-in (progressive enhancement) */
    @media (prefers-reduced-motion: no-preference) {
      @supports (animation-timeline: view()) {
        .entry {
          opacity: 0;
          animation: entry-rise 0.4s ease both;
          animation-timeline: view();
          animation-range: entry 0% entry 30%;
        }
        @keyframes entry-rise {
          from { opacity: 0; transform: translateY(12px); }
          to { opacity: 1; transform: translateY(0); }
        }
      }
    }

    @media (max-width: 640px) {
      .entry {
        grid-template-columns: 1fr;
        gap: 0.4rem;
      }
    }
  </style>

  <script is:inline>
    (function () {
      var API = 'https://announcements.univerlab.org';
      var container = document.getElementById('log-entries');
      if (!container) return;

      var isDev = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
      var MOCK = [
        { date: '2026-07-17T22:00:00Z', type: 'note', title: 'Dress rehearsal', body: 'Before a vehicle flies, it runs a dress rehearsal: the full countdown on the pad, tanks loaded, every system exercised in sequence, stopping just short of ignition. Nothing leaves the ground. The point is to find out what breaks while breaking it is still cheap.' },
        { date: '2026-07-17T18:00:00Z', type: 'launch', title: 'First light', body: 'Astronomers call it first light: the moment a new instrument opens its eye and returns an image. That first picture is never the best one the telescope will ever take. It is the proof that the optics align, the detector responds, the data path is open.' },
        { date: '2026-07-17T12:00:00Z', type: 'deploy', title: 'Announcements worker online', body: 'The announcements Durable Object is live. Entries serialize through SQLite, fan out over SSE, and mirror to KV for fast reads. The first transmission reached the log without incident.' },
        { date: '2026-07-17T09:00:00Z', type: 'note', title: 'Status page ships', body: 'The status page is now part of the public site. Real-time entries, infinite scroll, toast notifications for live updates, and a cosmic background that matches the mission log aesthetic.' },
        { date: '2026-07-16T20:00:00Z', type: 'bugfix', title: 'Skeleton placeholders cleared', body: 'The skeleton loading placeholders were not being removed when the first batch of entries loaded. A one-line fix clears the container before appending real entries.' }
      ];

      var PAGE = 20;
      var offset = 0;
      var loading = false;
      var hasMore = true;

      function formatDate(iso) {
        var d = new Date(iso);
        var y = d.getFullYear();
        var start = new Date(y, 0, 0);
        var dayOfYear = Math.floor((d - start) / 86400000);
        return 'TERRA ' + y + ' \u00b7 Sol ' + dayOfYear;
      }

      function renderEntry(entry) {
        var article = document.createElement('article');
        article.className = 'entry';

        var time = document.createElement('time');
        time.setAttribute('datetime', entry.date);
        time.textContent = formatDate(entry.date);
        article.appendChild(time);

        var body = document.createElement('div');
        body.className = 'entry-body';

        if (entry.type) {
          var badge = document.createElement('div');
          badge.className = 'type-badge';
          badge.textContent = entry.type;
          body.appendChild(badge);
        }

        var h3 = document.createElement('h3');
        h3.textContent = entry.title;
        body.appendChild(h3);

        var p = document.createElement('p');
        p.textContent = entry.body;
        body.appendChild(p);

        article.appendChild(body);
        return article;
      }

      function appendEntries(entries) {
        if (!Array.isArray(entries) || !entries.length) return;
        var frag = document.createDocumentFragment();
        entries.forEach(function (e) { frag.appendChild(renderEntry(e)); });
        container.appendChild(frag);
      }

      function loadMore() {
        if (loading || !hasMore) return;
        loading = true;

        if (isDev) {
          if (offset === 0) container.innerHTML = '';
          var batch = MOCK.slice(offset, offset + PAGE);
          appendEntries(batch);
          offset += batch.length;
          hasMore = offset < MOCK.length;
          loading = false;
          if (!hasMore) observer.disconnect();
          return;
        }

        fetch(API + '?offset=' + offset + '&limit=' + PAGE)
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (offset === 0) container.innerHTML = '';
            appendEntries(data.entries);
            offset += data.entries.length;
            hasMore = data.hasMore;
            loading = false;
            if (!hasMore) observer.disconnect();
          })
          .catch(function () { loading = false; });
      }

      function prependEntry(entry) {
        var el = renderEntry(entry);
        container.prepend(el);
        offset++;
        showToast(entry.title);
      }

      function showToast(title) {
        var toast = document.createElement('div');
        toast.className = 'toast';
        toast.textContent = 'New entry: ' + title;
        document.body.appendChild(toast);
        setTimeout(function () {
          toast.classList.add('fade-out');
          setTimeout(function () { toast.remove(); }, 300);
        }, 4000);
      }

      // Infinite scroll sentinel
      var sentinel = document.createElement('div');
      sentinel.className = 'scroll-sentinel';
      container.parentElement.appendChild(sentinel);

      var observer = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) loadMore();
      }, { rootMargin: '200px' });
      observer.observe(sentinel);

      // Initial load
      loadMore();

      // SSE
      if (!isDev) {
        var source = new EventSource(API + '/events');
        source.addEventListener('entry', function (e) {
          try {
            var entry = JSON.parse(e.data);
            prependEntry(entry);
          } catch (err) {}
        });
        source.onerror = function () {};
      }
    })();
  </script>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Astro Denoise — the dark room. Essence: deep space; faint signals teased
// out of noise; violet starlight on long exposure.
const stars = Array.from({ length: 70 }, (_, i) => ({
  cx: ((i * 137.508) % 100),
  cy: ((i * 73.13) % 56),
  r: 0.4 + ((i * 7) % 10) / 12,
  o: 0.25 + ((i * 13) % 10) / 14,
}));
---
<BaseLayout
  title="Astro Denoise — UniverLab"
  description="Astro Denoise: denoising benchmark research on DESC DC2 / LSST astronomical data."
>
  <div class="space">
    <svg class="sky" viewBox="0 0 100 56" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      {stars.map((s) => (
        <circle cx={s.cx} cy={s.cy} r={s.r} fill="var(--astro-denoise)" opacity={s.o} />
      ))}
    </svg>

    <section class="wrap hero">
      <p class="label num">EXP-006 · RESEARCH</p>
      <h1>Astro Denoise</h1>
      <p class="koan">Most of the universe arrives as noise.</p>
      <p class="lede prose">
        Telescope surveys drown faint galaxies in sensor noise. This research
        track benchmarks denoising methods on <strong>DESC DC2 / LSST</strong>
        simulated data — measuring what each method preserves, what it
        invents, and what it destroys, so that cleaned images remain honest
        scientific evidence.
      </p>
      <div class="actions">
        <a class="btn" href="https://github.com/UniverLab">Follow the lab ↗</a>
        <span class="install mono">papers &amp; datasets in preparation</span>
      </div>
    </section>

    <section class="wrap section">
      <span class="label">Questions under study</span>
      <ul class="qs">
        <li>Which denoisers preserve photometry instead of repainting it?</li>
        <li>How do classical and learned methods degrade at LSST depth?</li>
        <li>Can a benchmark make “cleaner” mean “more truthful”, not just “smoother”?</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .space { position: relative; overflow: hidden; }
  .sky {
    position: absolute;
    inset: 0 0 auto 0;
    width: 100%;
    height: 24rem;
    pointer-events: none;
  }
  .hero { position: relative; padding-block: 5rem 2rem; }
  .num { color: var(--astro-denoise); }
  h1 { font-size: clamp(2.4rem, 6vw, 4rem); margin-block: 0.5rem; }
  .koan { font-family: var(--font-serif); font-style: italic; color: var(--astro-denoise); opacity: 0.9; margin: 0 0 1.4rem; }
  .lede { color: var(--ink-dim); font-size: 1.08rem; }
  .lede strong { color: var(--ink); font-weight: 500; }

  .actions { display: flex; gap: 1.2rem; align-items: center; flex-wrap: wrap; margin-top: 2rem; }
  .btn {
    text-decoration: none;
    border: 1px solid var(--astro-denoise);
    color: var(--astro-denoise);
    padding: 0.55rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .btn:hover { background: var(--astro-denoise); color: var(--bg); }
  .install { color: var(--ink-faint); font-size: 0.8rem; }

  .section { padding-block: 2.5rem 4rem; }
  .qs { list-style: none; padding: 0; margin: 1.2rem 0 0; max-width: 40rem; }
  .qs li {
    padding-block: 0.7rem;
    border-bottom: 1px solid color-mix(in srgb, var(--astro-denoise) 20%, var(--line));
    color: var(--ink-dim);
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Texforge — the print shop. Essence: warm ink on paper, typography itself,
// the quiet heat of a forge that casts documents instead of type.
---
<BaseLayout
  title="Texforge — UniverLab"
  description="Texforge: a unified LaTeX workspace — writing, diagrams and PDFs in one self-contained tool."
>
  <div class="press">
    <section class="wrap hero">
      <p class="label num">EXP-001 · ACTIVE</p>
      <h1>Tex<span class="lig">forge</span></h1>
      <p class="koan">Movable type once took a workshop. Now it takes one binary.</p>
      <p class="lede prose">
        Writing LaTeX should not require installing four gigabytes of
        toolchain. Texforge is a single Rust binary that scaffolds, lints,
        formats and compiles documents — the LaTeX engine arrives by itself on
        first build, and Mermaid or Graphviz diagrams render inside your
        <code>.tex</code> files with no browser and no Node.js.
      </p>
      <div class="actions">
        <a class="btn" href="https://github.com/UniverLab/texforge">Source &amp; docs ↗</a>
        <code class="install">cargo install texforge</code>
      </div>
    </section>

    <section class="wrap section">
      <div class="galley">
        <pre class="mono plate"><code>$ texforge new quantum-paper
$ cd quantum-paper
$ texforge build
  ◇ quantum-paper.pdf</code></pre>
        <div class="colophon">
          <span class="label">The whole press</span>
          <ul>
            <li><strong>Compose</strong> — templates with placeholders that already know your name.</li>
            <li><strong>Proof</strong> — a linter that catches broken refs, missing files and unclosed environments before the press runs.</li>
            <li><strong>Set</strong> — one canonical format, like rustfmt for .tex. Clean diffs forever.</li>
            <li><strong>Illustrate</strong> — Mermaid and Graphviz blocks become figures at build time, rendered in pure Rust.</li>
            <li><strong>Print</strong> — Tectonic compiles deterministically; watch mode reprints as you write.</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Paper-and-ink essence: warm cast, serif voice, a faint sheet of light */
  .press {
    background:
      radial-gradient(55rem 26rem at 80% -10%, color-mix(in srgb, var(--texforge) 12%, transparent), transparent 65%);
  }
  .hero { padding-block: 4.5rem 2rem; }
  .num { color: var(--texforge); }
  h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(2.6rem, 6.5vw, 4.4rem);
    margin-block: 0.5rem;
  }
  .lig { font-style: italic; color: var(--texforge); }
  .koan {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--texforge);
    opacity: 0.85;
    margin: 0 0 1.4rem;
  }
  .lede { color: var(--ink-dim); font-size: 1.08rem; }

  .actions { display: flex; gap: 1.2rem; align-items: center; flex-wrap: wrap; margin-top: 2rem; }
  .btn {
    text-decoration: none;
    border: 1px solid var(--texforge);
    color: var(--texforge);
    padding: 0.55rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .btn:hover { background: var(--texforge); color: var(--bg); }
  .install { color: var(--ink-dim); font-size: 0.85rem; }

  .section { padding-block: 3rem 4rem; }
  .galley {
    display: grid;
    grid-template-columns: minmax(18rem, 1fr) 1.3fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 50rem) { .galley { grid-template-columns: 1fr; } }

  /* The plate: a block of set type */
  .plate {
    margin: 0;
    padding: 1.6rem;
    border: 1px solid color-mix(in srgb, var(--texforge) 35%, var(--line));
    background: var(--bg-raise);
    color: var(--texforge);
    font-size: 0.9rem;
    line-height: 1.9;
    box-shadow: 0.5rem 0.5rem 0 color-mix(in srgb, var(--texforge) 14%, transparent);
  }

  .colophon ul { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .colophon li {
    padding-block: 0.7rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink-dim);
    font-size: 0.97rem;
  }
  .colophon strong {
    color: var(--ink);
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: italic;
    margin-right: 0.4rem;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Cadforge — the drafting table. Essence: blueprint grid, dimension lines,
// cyan ink on dark vellum. The plan is declared, not drawn.
---
<BaseLayout
  title="Cadforge — UniverLab"
  description="Cadforge: Architecture as Code — declarative 2D CAD compiled deterministically to DXF."
>
  <div class="vellum">
    <section class="wrap hero">
      <p class="label num">EXP-005 · BETA</p>
      <h1>Cadforge</h1>
      <p class="koan">The plan is not drawn. It is declared.</p>
      <p class="lede prose">
        Architectural plans are collections of lines without semantics —
        impossible to version, diff or automate. Cadforge treats a floor plan
        like source code: geometry declared in TOML, previewed live in the
        browser, compiled to a <strong>bit-identical DXF</strong> every time.
        <code>git diff</code> works on buildings now.
      </p>
      <div class="actions">
        <a class="btn" href="https://github.com/UniverLab/cadforge">Source &amp; docs ↗</a>
        <code class="install">cargo install cadforge</code>
      </div>
    </section>

    <section class="wrap section">
      <div class="sheet">
        <div class="drawing">
          <svg viewBox="0 0 320 200" aria-hidden="true">
            <!-- plan: simple room with door arc + dimension line -->
            <g stroke="var(--cadforge)" stroke-width="2" fill="none">
              <rect x="40" y="30" width="240" height="130" />
              <line x1="150" y1="30" x2="150" y2="100" />
              <path d="M150 100 A 38 38 0 0 1 188 138" stroke-dasharray="4 4" stroke-width="1.2" />
              <line x1="150" y1="138" x2="188" y2="138" />
            </g>
            <g stroke="var(--cadforge)" stroke-width="1" opacity="0.65">
              <line x1="40" y1="178" x2="280" y2="178" />
              <line x1="40" y1="172" x2="40" y2="184" />
              <line x1="280" y1="172" x2="280" y2="184" />
            </g>
            <text x="148" y="192" class="mono" fill="var(--cadforge)" font-size="9">8.50</text>
            <text x="58" y="52" class="mono" fill="var(--ink-dim)" font-size="9">muros</text>
          </svg>
        </div>
        <pre class="mono code"><code>[[line]]
id = "ln-001"
from = [0.0, 0.0]
to = [8.5, 0.0]
weight = 0.50

[[dim]]
id = "dm-001"
from = [0, 0]
to = [8.5, 0]
offset = 0.5</code></pre>
      </div>

      <ul class="notes">
        <li><span class="mono note-num">N1</span> Live preview server: edit a <code>.cf</code> file, the browser updates on save. Errors overlay instead of crashing.</li>
        <li><span class="mono note-num">N2</span> Built for AI agents: <code>cadforge schema</code> teaches the language in one command; previews ship per-entity bounding boxes so agents can <em>see</em> the plan.</li>
        <li><span class="mono note-num">N3</span> Deterministic DXF out, legacy DXF in — existing drawings migrate into the declarative workflow.</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  /* Blueprint essence: drafting grid fading in from the top */
  .vellum {
    background:
      linear-gradient(color-mix(in srgb, var(--cadforge) 5%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--cadforge) 5%, transparent) 1px, transparent 1px),
      radial-gradient(50rem 24rem at 50% -8%, color-mix(in srgb, var(--cadforge) 9%, transparent), transparent 62%);
    background-size: 2.2rem 2.2rem, 2.2rem 2.2rem, auto;
  }
  .hero { padding-block: 4.5rem 2rem; }
  .num { color: var(--cadforge); }
  h1 { font-size: clamp(2.4rem, 6vw, 4rem); margin-block: 0.5rem; letter-spacing: 0.02em; }
  .koan { font-family: var(--font-serif); font-style: italic; color: var(--cadforge); opacity: 0.85; margin: 0 0 1.4rem; }
  .lede { color: var(--ink-dim); font-size: 1.08rem; }
  .lede strong { color: var(--ink); font-weight: 500; }
  .lede code { color: var(--cadforge); font-size: 0.9em; }

  .actions { display: flex; gap: 1.2rem; align-items: center; flex-wrap: wrap; margin-top: 2rem; }
  .btn {
    text-decoration: none;
    border: 1px solid var(--cadforge);
    color: var(--cadforge);
    padding: 0.55rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .btn:hover { background: var(--cadforge); color: var(--bg); }
  .install { color: var(--ink-dim); font-size: 0.85rem; }

  .section { padding-block: 3rem 4rem; }
  .sheet {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1px;
    background: color-mix(in srgb, var(--cadforge) 35%, var(--line));
    border: 1px solid color-mix(in srgb, var(--cadforge) 35%, var(--line));
    max-width: 46rem;
  }
  @media (max-width: 44rem) { .sheet { grid-template-columns: 1fr; } }
  .drawing { background: var(--bg-raise); padding: 1rem; }
  .drawing svg { display: block; width: 100%; }
  .code {
    margin: 0;
    background: var(--bg-raise);
    padding: 1.2rem;
    font-size: 0.8rem;
    line-height: 1.65;
    color: var(--cadforge);
  }

  .notes { list-style: none; padding: 0; margin: 2.2rem 0 0; max-width: 46rem; }
  .notes li {
    display: flex;
    gap: 1rem;
    padding-block: 0.7rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink-dim);
    font-size: 0.97rem;
  }
  .note-num { color: var(--cadforge); font-size: 0.8rem; padding-top: 0.15rem; }
  .notes code { color: var(--cadforge); font-size: 0.88em; }
</style>

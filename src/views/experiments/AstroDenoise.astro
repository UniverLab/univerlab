---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments['astro-denoise'];
---
<ExperimentLayout id="astro-denoise">
  <span slot="cta" class="papers mono">{e.papersSoon}</span>

  <section class="wrap section">
    <span class="label">{e.questions.kicker}</span>
    <ul class="qs">
      {e.questions.items.map((q) => <li>{q}</li>)}
    </ul>
  </section>

  <section class="wrap section research">
    <span class="label">{t.research.kicker}</span>
    <h2>{t.research.title}</h2>
    <p class="prose rintro" set:html={t.research.intro} />
    <ul class="rlist">
      {t.research.items.map(([name, desc]) => (
        <li>
          <span class="badge label">{t.common.inPreparation}</span>
          <h3>{name}</h3>
          <p>{desc}</p>
        </li>
      ))}
    </ul>
  </section>
</ExperimentLayout>

<style>
  .papers { color: var(--ink-faint); font-size: 0.8rem; }
  .section { padding-block: 1.5rem 2rem; }
  .qs { list-style: none; padding: 0; margin: 1.2rem 0 0; max-width: 40rem; }
  .qs li { padding-block: 0.7rem; border-bottom: 1px solid color-mix(in srgb, var(--astro-denoise) 20%, var(--line)); color: var(--ink-dim); }

  .research { padding-block: 2.5rem 4.5rem; }
  .research h2 { font-size: 1.5rem; margin-block: 0.5rem 1rem; }
  .rintro { color: var(--ink-dim); max-width: 48rem; margin-bottom: 1.6rem; }

  .rlist {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: 1rem;
  }
  .rlist li {
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border: 1px solid var(--line);
    border-left: 2px solid transparent; /* accent bar, lit on hover */
    padding: 1.6rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    transition: background 0.15s ease, border-left-color 0.15s ease;
    backdrop-filter: blur(2px);
  }
  .rlist li:hover {
    background: var(--bg-raise);
    border-left-color: var(--astro-denoise);
  }
  .badge {
    display: inline-block;
    padding: 0.15rem 0.45rem;
    background: color-mix(in srgb, var(--astro-denoise) 12%, transparent);
    color: var(--astro-denoise);
    border: 1px solid color-mix(in srgb, var(--astro-denoise) 25%, transparent);
    border-radius: 2px;
    font-size: 0.65rem;
    margin-bottom: 0.3rem;
    align-self: flex-start;
  }
  .rlist h3 { font-size: 1rem; font-weight: 500; margin: 0; color: var(--ink); }
  .rlist p { color: var(--ink-dim); font-size: 0.9rem; margin: 0; line-height: 1.55; }
</style>

---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments.cadspec;
---
<ExperimentLayout id="cadspec">
  <section class="wrap section">
    <div class="sheet">
      <div class="drawing">
        <svg viewBox="0 0 320 200" aria-hidden="true">
          <!-- room walls (ink), with a window gap on top and a door gap on bottom -->
          <g class="walls" stroke="var(--ink)" stroke-width="3" fill="none" stroke-linecap="square">
            <path d="M50 34 H120 M175 34 H270 V146 H215 M175 146 H50 V34" />
          </g>
          <!-- window in the top wall -->
          <g class="window" stroke="var(--essence)" stroke-width="1.3">
            <line x1="120" y1="32" x2="175" y2="32" />
            <line x1="120" y1="36" x2="175" y2="36" />
          </g>
          <!-- door: a swing trace, and a leaf that opens and closes -->
          <path class="swing" d="M215 146 A 40 40 0 0 0 175 106" stroke="var(--essence)" stroke-width="1.2" stroke-dasharray="4 4" fill="none" />
          <g class="door">
            <line x1="175" y1="146" x2="215" y2="146" stroke="var(--essence)" stroke-width="2" />
          </g>
          <!-- dimensions -->
          <g class="dims" stroke="var(--essence)" stroke-width="1" opacity="0.85">
            <line x1="50" y1="170" x2="270" y2="170" />
            <line x1="50" y1="166" x2="50" y2="174" />
            <line x1="270" y1="166" x2="270" y2="174" />
            <line x1="30" y1="34" x2="30" y2="146" />
            <line x1="26" y1="34" x2="34" y2="34" />
            <line x1="26" y1="146" x2="34" y2="146" />
          </g>
          <text x="160" y="184" class="mono dim-t" text-anchor="middle" font-size="9">8.50</text>
          <text x="20" y="90" class="mono dim-t" text-anchor="middle" font-size="9" transform="rotate(-90 20 90)">4.20</text>
          <!-- north arrow -->
          <g class="north" stroke="var(--ink-dim)" stroke-width="1" fill="none">
            <path d="M298 66 V50" />
            <path d="M294.5 55 L298 49 L301.5 55" />
          </g>
          <text x="298" y="80" class="mono" text-anchor="middle" fill="var(--ink-dim)" font-size="8">N</text>
        </svg>
      </div>
      <pre class="mono code"><code>[[line]]
id = "ln-001"
from = [0.0, 0.0]
to = [8.5, 0.0]
weight = 0.50

[[dim]]
id = "dm-001"
from = [0, 0]
to = [8.5, 0]
offset = 0.5</code></pre>
    </div>

    <ul class="notes">
      {e.notes.items.map((n, i) => (
        <li><span class="mono note-num">N{i + 1}</span><span set:html={n} /></li>
      ))}
    </ul>
  </section>
</ExperimentLayout>

<style>
  .section { padding-block: 1.5rem 2rem; }
  .sheet {
    display: grid; grid-template-columns: 1.3fr 1fr; gap: 1px;
    background: color-mix(in srgb, var(--cadspec) 35%, var(--line));
    border: 1px solid color-mix(in srgb, var(--cadspec) 35%, var(--line));
    max-width: 46rem;
  }
  @media (max-width: 44rem) { .sheet { grid-template-columns: 1fr; } }
  /* centre the plan in its cell, beside the (taller) code block */
  .drawing { background: var(--bg-raise); padding: 1rem; display: flex; align-items: center; justify-content: center; }
  .drawing svg { display: block; width: 100%; }
  .dim-t { fill: var(--essence); }
  /* the door opens and closes — a plan that breathes (off under reduced-motion). */
  .drawing svg .door {
    transform-box: view-box;
    transform-origin: 175px 146px;
    animation: cf-door 4.5s ease-in-out infinite;
  }
  @keyframes cf-door {
    0%, 12% { transform: rotate(0deg); }
    50%, 62% { transform: rotate(-90deg); }
    100% { transform: rotate(0deg); }
  }
  .code { margin: 0; background: var(--bg-raise); padding: 1.2rem; font-size: 0.8rem; line-height: 1.65; color: var(--cadspec); }
  .notes { list-style: none; padding: 0; margin: 2rem 0 0; max-width: 46rem; }
  .notes li { display: flex; gap: 1rem; padding-block: 0.7rem; border-bottom: 1px solid var(--line); color: var(--ink-dim); font-size: 0.97rem; }
  .note-num { color: var(--cadspec); font-size: 0.8rem; padding-top: 0.15rem; }
  .notes :global(code) { color: var(--cadspec); font-size: 0.88em; }
  .notes :global(em) { color: var(--cadspec); font-style: italic; }
</style>

---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments.cadspec;
---
<ExperimentLayout id="cadspec">
  <section class="wrap section">
    <div class="sheet">
      <div class="drawing">
        <svg viewBox="0 0 320 200" id="cs-plan" aria-hidden="true">
          <!-- room walls — the right wall slides as the width spec changes; a
               window gap on top and a door gap on the bottom stay put -->
          <path class="walls" d="M50 146 V34 H70 M110 34 H280 V146 H145 M110 146 H50"
            stroke="var(--ink)" stroke-width="3" fill="none" stroke-linecap="square" />
          <g class="window" stroke="var(--essence)" stroke-width="1.3">
            <line x1="70" y1="32" x2="110" y2="32" />
            <line x1="70" y1="36" x2="110" y2="36" />
          </g>
          <path class="swing" d="M145 146 A 35 35 0 0 0 110 111" stroke="var(--essence)" stroke-width="1.2" stroke-dasharray="4 4" fill="none" />
          <line x1="110" y1="146" x2="110" y2="111" stroke="var(--essence)" stroke-width="2" />
          <!-- width dimension: line, end ticks and value, all driven by the spec -->
          <g class="dims" stroke="var(--essence)" stroke-width="1" opacity="0.85">
            <line class="dim-line" x1="50" y1="168" x2="280" y2="168" />
            <line x1="50" y1="164" x2="50" y2="174" />
            <line class="dim-tick-r" x1="280" y1="164" x2="280" y2="174" />
            <line x1="30" y1="34" x2="30" y2="146" />
            <line x1="26" y1="34" x2="34" y2="34" />
            <line x1="26" y1="146" x2="34" y2="146" />
          </g>
          <text class="dim-label mono dim-t" x="165" y="184" text-anchor="middle" font-size="9">8.50</text>
          <text class="mono dim-t" x="20" y="90" text-anchor="middle" font-size="9" transform="rotate(-90 20 90)">4.20</text>
        </svg>
      </div>
      <pre class="mono code"><code id="cs-toml">[[line]]
id = "ln-001"
from = [0.0, 0.0]
to = [8.50, 0.0]
weight = 0.50

[[dim]]
id = "dm-001"
from = [0, 0]
to = [8.50, 0]
offset = 0.5</code></pre>
    </div>

    <ul class="notes">
      {e.notes.items.map((n, i) => (
        <li><span class="mono note-num">N{i + 1}</span><span set:html={n} /></li>
      ))}
    </ul>
  </section>
</ExperimentLayout>

<script>
  // cadspec is declarative: the spec drives the drawing. So the width in the
  // .toml steps between a few values and the plan redraws in lock-step — the
  // right wall slides, the dimension follows, the measured value counts. The
  // number you'd edit and the geometry it produces move together.
  (function () {
    const svg = document.getElementById('cs-plan');
    const toml = document.getElementById('cs-toml');
    if (!svg || !toml) return;
    const walls = svg.querySelector('.walls');
    const dimLine = svg.querySelector('.dim-line');
    const dimTick = svg.querySelector('.dim-tick-r');
    const dimLabel = svg.querySelector('.dim-label');
    if (!walls || !dimLine || !dimTick || !dimLabel) return;

    const LEFT = 50;
    const SCALE = 27; // px per metre
    const fmt = (w) => w.toFixed(2);
    const tomlText = (w) =>
      '[[line]]\nid = "ln-001"\nfrom = [0.0, 0.0]\nto = [' + fmt(w) +
      ', 0.0]\nweight = 0.50\n\n[[dim]]\nid = "dm-001"\nfrom = [0, 0]\nto = [' +
      fmt(w) + ', 0]\noffset = 0.5';

    function apply(w) {
      const R = Math.round(LEFT + SCALE * w);
      walls.setAttribute('d', 'M50 146 V34 H70 M110 34 H' + R + ' V146 H145 M110 146 H50');
      dimLine.setAttribute('x2', String(R));
      dimTick.setAttribute('x1', String(R));
      dimTick.setAttribute('x2', String(R));
      dimLabel.setAttribute('x', String((LEFT + R) / 2));
      dimLabel.textContent = fmt(w);
      toml.textContent = tomlText(w);
    }

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const targets = [8.5, 6.4, 5.2, 7.3]; // metres — the values that get "edited"
    const TWEEN = 850; // ms to redraw to the next value
    const HOLD = 2200; // ms resting on a clean value
    const ease = (k) => (k < 0.5 ? 2 * k * k : 1 - Math.pow(-2 * k + 2, 2) / 2);

    let i = 0;
    let from = targets[0];
    let to = targets[1];
    let phase = null;
    let raf = null;
    function frame(ts) {
      if (phase === null) phase = ts;
      const e2 = ts - phase;
      if (e2 < TWEEN) apply(from + (to - from) * ease(e2 / TWEEN));
      else if (e2 < TWEEN + HOLD) apply(to);
      else {
        phase = ts;
        i = (i + 1) % targets.length;
        from = targets[i];
        to = targets[(i + 1) % targets.length];
        apply(from);
      }
      raf = requestAnimationFrame(frame);
    }
    const io = new IntersectionObserver((entries) => {
      for (const en of entries) {
        if (en.isIntersecting && raf === null) { phase = null; raf = requestAnimationFrame(frame); }
        else if (!en.isIntersecting && raf !== null) { cancelAnimationFrame(raf); raf = null; }
      }
    });
    io.observe(svg);
  })();
</script>

<style>
  .section { padding-block: 1.5rem 2rem; }
  .sheet {
    display: grid; grid-template-columns: 1.3fr 1fr; gap: 1px;
    background: color-mix(in srgb, var(--cadspec) 35%, var(--line));
    border: 1px solid color-mix(in srgb, var(--cadspec) 35%, var(--line));
    max-width: 46rem; margin-inline: auto;
  }
  @media (max-width: 44rem) { .sheet { grid-template-columns: 1fr; } }
  /* centre the plan in its cell, beside the (taller) code block */
  .drawing { background: var(--bg-raise); padding: 1rem; display: flex; align-items: center; justify-content: center; }
  .drawing svg { display: block; width: 100%; }
  .dim-t { fill: var(--essence); }
  .code { margin: 0; background: var(--bg-raise); padding: 1.2rem; font-size: 0.8rem; line-height: 1.65; color: var(--cadspec); }
  .notes { list-style: none; padding: 0; margin: 2rem auto 0; max-width: 46rem; }
  .notes li { display: flex; gap: 1rem; padding-block: 0.7rem; border-bottom: 1px solid var(--line); color: var(--ink-dim); font-size: 0.97rem; }
  .note-num { color: var(--cadspec); font-size: 0.8rem; padding-top: 0.15rem; }
  .notes :global(code) { color: var(--cadspec); font-size: 0.88em; }
  .notes :global(em) { color: var(--cadspec); font-style: italic; }
</style>

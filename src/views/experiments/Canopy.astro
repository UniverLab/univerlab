---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments.canopy;

// Read supported platforms from canopy-registry at build time.
const registryPath = resolve(process.cwd(), '../canopy-registry/index.toml');
const registryToml = readFileSync(registryPath, 'utf-8');
const platforms = [...registryToml.matchAll(/\[\[platforms\]\]\s*name\s*=\s*"([^"]+)"/g)]
  .map((m) => m[1]);
---
<ExperimentLayout id="canopy">
  <section class="wrap section">
    <span class="label">{e.layer.kicker}</span>
    <div class="cols">
      {e.layer.cols.map(([h, b]) => (
        <div class="col"><h3>{h}</h3><p>{b}</p></div>
      ))}
    </div>
  </section>

  <section class="wrap section">
    <span class="label">{e.platforms.kicker}</span>
    <ul class="platforms">
      {platforms.map((name) => (
        <li>{name}</li>
      ))}
    </ul>
  </section>

  <section class="wrap section">
    <span class="label">{e.loops.kicker}</span>
    <div class="cols">
      {e.loops.cols.map(([h, b]) => (
        <div class="col"><h3>{h}</h3><p>{b}</p></div>
      ))}
    </div>
  </section>
</ExperimentLayout>

<style>
  .section { padding-block: 2rem; }
  .cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); gap: 2.2rem; margin-top: 1.4rem; }
  .col { border-top: 2px solid color-mix(in srgb, var(--canopy) 45%, transparent); padding-top: 1rem; }
  .col h3 { color: var(--canopy); font-size: 1.05rem; margin-bottom: 0.5rem; }
  .col p { margin: 0; color: var(--ink-dim); font-size: 0.95rem; }
  .platforms { list-style: none; padding: 0; margin: 1.4rem 0 0; max-width: 42rem; display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .platforms li {
    font-family: var(--font-mono); font-size: 0.82rem; letter-spacing: 0.04em;
    color: var(--ink-dim); padding: 0.35rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--canopy) 25%, var(--line));
    border-radius: 2px;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .platforms li:hover { border-color: var(--canopy); color: var(--canopy); }
</style>

---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments['quorum'];

// The planning-poker deck, fanned like a hand. The middle card is lifted as if
// it has just been played.
const deck = ['0', '1', '2', '3', '5', '8', '13', '21', '?'];
const mid = (deck.length - 1) / 2;
---
<ExperimentLayout id="quorum">
  <a slot="cta" class="btn ghost launch" href="https://quorum.univerlab.org" target="_blank" rel="noopener noreferrer">{t.common.launch}</a>

  <section class="wrap section">
    <!-- The deck, fanned like a hand of cards — the estimate about to be played. -->
    <figure class="deck-fig" aria-hidden="true">
      <div class="deck">
        {deck.map((v, i) => (
          <div class:list={['pc', { sel: i === mid }]} style={`--a:${(i - mid) * 8}deg`}>
            <span>{v}</span>
          </div>
        ))}
      </div>
      <p class="fig-label mono">the deck</p>
    </figure>

    <div class="features">
      <span class="label">{e.how.kicker}</span>
      <ol>
        {e.how.items.map((item, i) => (
          <li>
            <span class="step">{String(i + 1).padStart(2, '0')}</span>
            <span set:html={item} />
          </li>
        ))}
      </ol>
    </div>
  </section>
</ExperimentLayout>

<style>
  .section {
    padding-block: 1.5rem 2.5rem;
    display: grid;
    grid-template-columns: minmax(18rem, 1fr) 1.1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 50rem) { .section { grid-template-columns: 1fr; } }

  /* Fanned planning-poker deck */
  .deck-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.8rem;
  }
  .deck {
    position: relative;
    width: 360px;
    height: 230px;
  }
  /* Cards share a pivot below the fan and spread by rotation — a held hand.
     The rank sits at the top of each card, so it shows even where they overlap. */
  .pc {
    position: absolute;
    left: 50%;
    bottom: 6px;
    width: 60px;
    height: 86px;
    margin-left: -30px;
    border-radius: 9px;
    border: 1.5px solid color-mix(in srgb, var(--essence) 55%, transparent);
    background: color-mix(in srgb, var(--essence) 8%, var(--bg-raise));
    display: flex;
    justify-content: center;
    padding-top: 8px;
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1;
    color: var(--essence);
    transform-origin: 50% 250%;
    transform: rotate(var(--a));
    box-shadow: 0 8px 22px color-mix(in srgb, #000 45%, transparent);
  }
  /* The played card lifts off the fan and brightens. */
  .pc.sel {
    align-items: center;
    padding-top: 0;
    font-size: 1.5rem;
    border-color: var(--essence);
    background: color-mix(in srgb, var(--essence) 20%, var(--bg-raise));
    box-shadow: 0 16px 34px color-mix(in srgb, var(--essence) 28%, transparent);
    transform: rotate(var(--a)) translateY(-26px);
    z-index: 3;
  }
  @media (prefers-reduced-motion: no-preference) {
    .pc.sel { animation: play 4.5s ease-in-out infinite; }
    @keyframes play {
      0%, 100% { transform: rotate(var(--a)) translateY(-26px); }
      50%      { transform: rotate(var(--a)) translateY(-34px); }
    }
  }

  .fig-label { font-size: 0.75rem; color: var(--ink-dim); letter-spacing: 0.16em; text-transform: uppercase; }

  /* Feature list */
  .features ol { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .features li {
    display: flex;
    gap: 0.9rem;
    align-items: baseline;
    padding-block: 0.7rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink-dim);
    font-size: 0.97rem;
  }
  .step {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--essence);
    flex: none;
    min-width: 1.5rem;
  }

  /* Launch CTA */
  :global(.launch) { color: var(--essence) !important; border-color: color-mix(in srgb, var(--essence) 50%, transparent) !important; }
  :global(.launch:hover) { background: color-mix(in srgb, var(--essence) 12%, transparent) !important; }
</style>

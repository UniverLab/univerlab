---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments['quorum'];
---
<ExperimentLayout id="quorum">
  <a slot="cta" class="btn ghost launch" href="https://quorum.univerlab.org" target="_blank" rel="noopener noreferrer">{t.common.launch}</a>

  <section class="wrap section">
    <!-- P2P room visual: three cards floating in formation to suggest a
         distributed table where no single node is the host. -->
    <figure class="room-fig" aria-hidden="true">
      <div class="table">
        <div class="card c1"><span>5</span></div>
        <div class="card c2"><span>8</span></div>
        <div class="card c3"><span>3</span></div>
        <div class="peer p1"></div>
        <div class="peer p2"></div>
        <div class="peer p3"></div>
        <div class="conn conn-12"></div>
        <div class="conn conn-13"></div>
        <div class="conn conn-23"></div>
      </div>
      <p class="fig-label mono">P2P — no server</p>
    </figure>

    <div class="features">
      <span class="label">{e.how.kicker}</span>
      <ol>
        {e.how.items.map((item, i) => (
          <li>
            <span class="step">{String(i + 1).padStart(2, '0')}</span>
            <span set:html={item} />
          </li>
        ))}
      </ol>
    </div>
  </section>
</ExperimentLayout>

<style>
  .section {
    padding-block: 1.5rem 2.5rem;
    display: grid;
    grid-template-columns: minmax(18rem, 1fr) 1.1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 50rem) { .section { grid-template-columns: 1fr; } }

  /* P2P room figure */
  .room-fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }
  .table {
    position: relative;
    width: 260px;
    height: 220px;
  }

  /* Peer nodes */
  .peer {
    position: absolute;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--essence);
    opacity: 0.55;
  }
  .p1 { top: 16px; left: 50%; transform: translateX(-50%); }
  .p2 { bottom: 16px; left: 22%; }
  .p3 { bottom: 16px; right: 22%; }

  /* Connection lines */
  .conn {
    position: absolute;
    background: color-mix(in srgb, var(--essence) 30%, transparent);
    height: 1px;
    transform-origin: left center;
  }
  .conn-12 { width: 108px; top: 20px; left: 50%; transform: translateX(-50%) rotate(57deg) translateX(0); top: 20px; left: 88px; transform: rotate(62deg); }
  .conn-13 { width: 108px; top: 20px; right: 48px; transform: rotate(118deg); }
  .conn-23 { width: 90px; bottom: 20px; left: 68px; }

  /* Floating cards */
  .card {
    position: absolute;
    width: 52px;
    height: 72px;
    border-radius: 8px;
    border: 1.5px solid color-mix(in srgb, var(--essence) 60%, transparent);
    background: color-mix(in srgb, var(--essence) 10%, var(--bg));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--essence);
    box-shadow: 0 6px 24px color-mix(in srgb, var(--essence) 15%, transparent);
  }
  .c1 { top: 44px; left: 50%; transform: translateX(-50%); animation: float 4s ease-in-out infinite; }
  .c2 { bottom: 44px; left: 14%; animation: float 4s ease-in-out infinite 1.3s; }
  .c3 { bottom: 44px; right: 14%; animation: float 4s ease-in-out infinite 2.6s; }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }
  .c1 { animation-name: float-center; }
  @keyframes float-center {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(-6px); }
  }

  .fig-label { font-size: 0.75rem; color: var(--ink-dim); letter-spacing: 0.04em; }

  /* Feature list */
  .features ol { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .features li {
    display: flex;
    gap: 0.9rem;
    align-items: baseline;
    padding-block: 0.7rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink-dim);
    font-size: 0.97rem;
  }
  .step {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--essence);
    flex: none;
    min-width: 1.5rem;
  }

  /* Launch CTA */
  :global(.launch) { color: var(--essence) !important; border-color: color-mix(in srgb, var(--essence) 50%, transparent) !important; }
  :global(.launch:hover) { background: color-mix(in srgb, var(--essence) 12%, transparent) !important; }
</style>

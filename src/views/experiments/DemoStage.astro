---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments['demostage'];
---
<ExperimentLayout id="demostage">
  <section class="wrap section">
    <!-- The signature: the artifact DemoStage produces — a terminal demo with a
         player scrubber, its steps marked along the timeline. -->
    <figure class="player" id="demo-player">
      <div class="bar mono">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="name">demo.cast</span>
      </div>
      <pre class="mono body" translate="no"><code>$ demo capture
  → demo.toml (8 steps) + demo.rec
$ demo record
  → demo.rec (clean humanized take)
$ demo export gif,mp4
  → dist/demo.gif  dist/demo.mp4</code></pre>
      <div class="scrubber mono">
        <span class="play" aria-hidden="true">▶</span>
        <div class="track">
          <span class="fill"></span>
          <span class="tick" style="left:20%"></span>
          <span class="tick" style="left:55%"></span>
          <span class="tick" style="left:82%"></span>
          <span class="head"></span>
        </div>
        <span class="tc">0:06</span>
      </div>
    </figure>
    <div class="features">
      <span class="label">{e.pipeline.kicker}</span>
      <ul>
        {e.pipeline.items.map((f, i) => <li><span class="step">{String(i + 1).padStart(2, '0')}</span><span set:html={f} /></li>)}
      </ul>
    </div>
  </section>
</ExperimentLayout>

<style>
  .section { padding-block: 1.5rem 2rem; display: grid; grid-template-columns: minmax(20rem, 1.1fr) 1fr; gap: 3rem; align-items: start; }
  @media (max-width: 50rem) { .section { grid-template-columns: 1fr; } }

  /* Demo player — a real terminal: a black monitor on the bright set, coral as
     its phosphor. The dark/light contrast lives here. */
  .player { margin: 0; border: 1px solid color-mix(in srgb, var(--demostage) 45%, #2a2520); border-radius: 9px; overflow: hidden; background: #14110d; box-shadow: 0 18px 45px rgba(0, 0, 0, 0.22); }
  .bar { display: flex; align-items: center; gap: 0.4rem; padding: 0.55rem 0.9rem; border-bottom: 1px solid #2a241d; font-size: 0.75rem; }
  .bar .d { width: 0.6rem; height: 0.6rem; border-radius: 50%; }
  .bar .d.r { background: #ef8354; } .bar .d.y { background: #e0c34a; } .bar .d.g { background: #5dd39e; }
  .bar .name { margin-left: 0.5rem; color: #8a8175; }
  /* min-height reserves the full session so the typewriter doesn't shift layout. */
  .body { margin: 0; padding: 1.2rem; font-size: 0.85rem; line-height: 1.8; color: var(--demostage); min-height: 9.5rem; }
  .scrubber { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0.9rem 0.7rem; border-top: 1px solid #2a241d; font-size: 0.72rem; }
  .scrubber .play { color: var(--demostage); font-size: 0.7rem; }
  .scrubber .track { position: relative; flex: 1; height: 3px; border-radius: 2px; background: #322b22; }
  .scrubber .fill { position: absolute; inset: 0 38% 0 0; background: var(--demostage); border-radius: 2px; }
  .scrubber .head { position: absolute; left: 62%; top: 50%; width: 0.62rem; height: 0.62rem; border-radius: 50%; background: var(--demostage); transform: translate(-50%, -50%); box-shadow: 0 0 9px color-mix(in srgb, var(--demostage) 70%, transparent); }
  .scrubber .tick { position: absolute; top: -2px; width: 1px; height: 7px; background: #4a4339; transform: translateX(-50%); transition: background .2s, box-shadow .2s; }
  .scrubber .tick.on { background: var(--demostage); box-shadow: 0 0 6px color-mix(in srgb, var(--demostage) 70%, transparent); }
  .scrubber .tc { color: #9a9082; }

  .features ul { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .features li { display: flex; gap: 0.9rem; align-items: baseline; padding-block: 0.7rem; border-bottom: 1px solid var(--line); color: var(--ink-dim); font-size: 0.97rem; }
  .step { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 500; color: var(--demostage); flex: none; min-width: 1.5rem; }
  .features :global(code) { color: var(--demostage); font-size: 0.88em; }
</style>

<script>
  // The landing of a demo tool should itself be a demo: the player types the
  // session, advances the scrubber, lights the step ticks, and loops. Honours
  // reduced-motion (leaves the static, fully-typed state) and only runs on screen.
  (function () {
    // Hero REC — a live session clock (mm:ss): the time you've been on the page.
    // Independent of the player, so it never freezes.
    const hero = document.querySelector('.exp .hero');
    if (hero) {
      hero.classList.add('js-rec');
      const rec = document.createElement('span');
      rec.className = 'rec';
      hero.appendChild(rec);
      const t0 = Date.now();
      const clock = () => {
        const s = Math.floor((Date.now() - t0) / 1000);
        rec.textContent = '● REC  ' + Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0');
      };
      clock();
      setInterval(clock, 1000);
    }

    // The player plays itself: typewriter + scrubber + lit step ticks, looping.
    const fig = document.getElementById('demo-player');
    if (!fig) return;
    const code = fig.querySelector('.body code');
    const fill = fig.querySelector('.fill');
    const head = fig.querySelector('.head');
    const tc = fig.querySelector('.tc');
    const ticks = Array.from(fig.querySelectorAll('.tick'));
    if (!code || !fill || !head || !tc) return;

    const full = code.textContent;
    const total = full.length || 1;
    const PLAY = 5000; // ms to play through
    const HOLD = 1600; // ms to rest at the end before replaying
    const pad = (n) => (n < 10 ? '0' + n : '' + n);

    function set(p) {
      const n = Math.round(total * p);
      code.textContent = full.slice(0, n) + (p < 1 ? '▍' : '');
      fill.style.right = (100 - p * 100).toFixed(2) + '%';
      head.style.left = (p * 100).toFixed(2) + '%';
      tc.textContent = '0:' + pad(Math.min(8, Math.round(p * 8)));
      for (const t of ticks) {
        const tp = parseFloat(t.style.left) / 100;
        t.classList.toggle('on', p >= tp);
      }
    }

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let start = null;
    let raf = null;
    function frame(ts) {
      if (start === null) start = ts;
      const e = ts - start;
      if (e <= PLAY) set(e / PLAY);
      else if (e <= PLAY + HOLD) set(1);
      else { start = ts; set(0); }
      raf = requestAnimationFrame(frame);
    }
    const io = new IntersectionObserver((entries) => {
      for (const en of entries) {
        if (en.isIntersecting && raf === null) { start = null; raf = requestAnimationFrame(frame); }
        else if (!en.isIntersecting && raf !== null) { cancelAnimationFrame(raf); raf = null; }
      }
    });
    io.observe(fig);
  })();
</script>

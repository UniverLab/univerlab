---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments['demo-stage'];
---
<ExperimentLayout id="demo-stage">
  <section class="wrap section">
    <!-- The signature: the artifact DemoStage produces — a terminal demo with a
         player scrubber, its steps marked along the timeline. -->
    <figure class="player" id="demo-player">
      <div class="bar mono">
        <span class="d r"></span><span class="d y"></span><span class="d g"></span>
        <span class="name">demo.cast</span>
      </div>
      <pre class="mono body" translate="no"><code>$ demo record -o macro.raw.toml
$ demo normalize macro.raw.toml
  → demo.toml (8 steps)
$ demo check demo.toml
  ok: demo.toml is valid
$ demo export demo.toml --target html
  → dist/demo.html</code></pre>
      <div class="scrubber mono">
        <span class="play" aria-hidden="true">▶</span>
        <div class="track">
          <span class="fill"></span>
          <span class="tick" style="left:14%"></span>
          <span class="tick" style="left:31%"></span>
          <span class="tick" style="left:48%"></span>
          <span class="tick" style="left:70%"></span>
          <span class="tick" style="left:86%"></span>
          <span class="head"></span>
        </div>
        <span class="tc">0:08</span>
      </div>
    </figure>
    <div class="features">
      <span class="label">{e.pipeline.kicker}</span>
      <ul>
        {e.pipeline.items.map((f) => <li set:html={f} />)}
      </ul>
    </div>
  </section>
</ExperimentLayout>

<style>
  .section { padding-block: 1.5rem 2rem; display: grid; grid-template-columns: minmax(20rem, 1.1fr) 1fr; gap: 3rem; align-items: start; }
  @media (max-width: 50rem) { .section { grid-template-columns: 1fr; } }

  /* Demo player — the artifact DemoStage outputs. */
  .player { margin: 0; border: 1px solid color-mix(in srgb, var(--demo-stage) 30%, var(--line)); border-radius: 8px; overflow: hidden; background: var(--bg-raise); box-shadow: 0 14px 40px rgba(0, 0, 0, 0.28); }
  .bar { display: flex; align-items: center; gap: 0.4rem; padding: 0.55rem 0.9rem; border-bottom: 1px solid var(--line); font-size: 0.75rem; }
  .bar .d { width: 0.6rem; height: 0.6rem; border-radius: 50%; }
  .bar .d.r { background: #ef8354; } .bar .d.y { background: #e0c34a; } .bar .d.g { background: #5dd39e; }
  .bar .name { margin-left: 0.5rem; color: var(--ink-faint); }
  /* min-height reserves the full session so the typewriter doesn't shift layout. */
  .body { margin: 0; padding: 1.2rem; font-size: 0.85rem; line-height: 1.8; color: var(--demo-stage); min-height: 11.5rem; }
  .scrubber { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0.9rem 0.7rem; border-top: 1px solid var(--line); font-size: 0.72rem; }
  .scrubber .play { color: var(--demo-stage); font-size: 0.7rem; }
  .scrubber .track { position: relative; flex: 1; height: 3px; border-radius: 2px; background: color-mix(in srgb, var(--demo-stage) 18%, var(--line)); }
  .scrubber .fill { position: absolute; inset: 0 38% 0 0; background: var(--demo-stage); border-radius: 2px; }
  .scrubber .head { position: absolute; left: 62%; top: 50%; width: 0.62rem; height: 0.62rem; border-radius: 50%; background: var(--demo-stage); transform: translate(-50%, -50%); box-shadow: 0 0 9px color-mix(in srgb, var(--demo-stage) 65%, transparent); }
  .scrubber .tick { position: absolute; top: -2px; width: 1px; height: 7px; background: color-mix(in srgb, var(--ink-faint) 75%, transparent); transform: translateX(-50%); transition: background .2s, box-shadow .2s; }
  .scrubber .tick.on { background: var(--demo-stage); box-shadow: 0 0 6px color-mix(in srgb, var(--demo-stage) 70%, transparent); }
  .scrubber .tc { color: var(--ink-dim); }

  .features ul { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .features li { padding-block: 0.7rem; border-bottom: 1px solid var(--line); color: var(--ink-dim); font-size: 0.97rem; }
  .features :global(code) { color: var(--demo-stage); font-size: 0.88em; }
</style>

<script>
  // The landing of a demo tool should itself be a demo: the player types the
  // session, advances the scrubber, lights the step ticks, and loops. Honours
  // reduced-motion (leaves the static, fully-typed state) and only runs on screen.
  (function () {
    const fig = document.getElementById('demo-player');
    if (!fig) return;
    const code = fig.querySelector('.body code');
    const fill = fig.querySelector('.fill');
    const head = fig.querySelector('.head');
    const tc = fig.querySelector('.tc');
    const ticks = Array.from(fig.querySelectorAll('.tick'));
    if (!code || !fill || !head || !tc) return;

    const full = code.textContent;
    const total = full.length || 1;
    const PLAY = 5000; // ms to play through
    const HOLD = 1600; // ms to rest at the end before replaying
    const pad = (n) => (n < 10 ? '0' + n : '' + n);

    function set(p) {
      const n = Math.round(total * p);
      code.textContent = full.slice(0, n) + (p < 1 ? '▍' : '');
      fill.style.right = (100 - p * 100).toFixed(2) + '%';
      head.style.left = (p * 100).toFixed(2) + '%';
      tc.textContent = '0:' + pad(Math.min(8, Math.round(p * 8)));
      for (const t of ticks) {
        const tp = parseFloat(t.style.left) / 100;
        t.classList.toggle('on', p >= tp);
      }
    }

    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let start = null;
    let raf = null;
    function frame(ts) {
      if (start === null) start = ts;
      const e = ts - start;
      if (e <= PLAY) set(e / PLAY);
      else if (e <= PLAY + HOLD) set(1);
      else { start = ts; set(0); }
      raf = requestAnimationFrame(frame);
    }
    const io = new IntersectionObserver((entries) => {
      for (const en of entries) {
        if (en.isIntersecting && raf === null) { start = null; raf = requestAnimationFrame(frame); }
        else if (!en.isIntersecting && raf !== null) { cancelAnimationFrame(raf); raf = null; }
      }
    });
    io.observe(fig);
  })();
</script>

---
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';
import { getLang, useTranslations } from '../../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const e = t.experiments.ghscaff;
---
<ExperimentLayout id="ghscaff">
  <section class="wrap section">
    <div class="frame">
      <span class="label">{e.lifts.kicker}</span>
      <ol class="lifts">
        {e.lifts.items.map((step, i) => (
          <li><span class="mono tick">{String(i + 1).padStart(2, '0')}</span><span>{step}</span></li>
        ))}
      </ol>
    </div>
    <div class="specsheet">
      <span class="label">{e.details.kicker}</span>
      <ul>
        {e.details.items.map((d) => <li set:html={d} />)}
      </ul>
    </div>
  </section>

  <section class="wrap section single">
    <div class="sub">
      <span class="label">{e.subproject.kicker}</span>
      <h3><a href={e.subproject.link}>{e.subproject.name} ↗</a></h3>
      <p set:html={e.subproject.body} />
    </div>
  </section>
</ExperimentLayout>

<style>
  .section { padding-block: 1.5rem; display: grid; grid-template-columns: minmax(15rem, 1fr) 1.4fr; gap: 3rem; align-items: start; }
  .section.single { display: block; }
  @media (max-width: 50rem) { .section { grid-template-columns: 1fr; } }
  .lifts { list-style: none; margin: 1.2rem 0 0; padding: 0; }
  .lifts li { display: flex; gap: 1rem; align-items: baseline; padding-block: 0.6rem; border-left: 2px solid color-mix(in srgb, var(--gitkit) 45%, var(--line)); padding-left: 1rem; }
  .tick { color: var(--gitkit); font-size: 0.8rem; }
  .specsheet ul { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .specsheet li { padding-block: 0.7rem; border-bottom: 1px solid var(--line); color: var(--ink-dim); font-size: 0.97rem; }
  .specsheet :global(strong) { color: var(--ink); font-weight: 500; }
  .specsheet :global(code) { color: var(--gitkit); font-size: 0.88em; }
  .sub { max-width: 46rem; }
  .sub h3 { font-size: 1.1rem; margin: 0.5rem 0; }
  .sub h3 a { color: var(--gitkit); text-decoration: none; }
  .sub p { margin: 0; color: var(--ink-dim); font-size: 0.97rem; }
</style>

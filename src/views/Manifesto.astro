---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n';
import { series, toSvgCoords, toSvgPoints, SVG_W, SVG_H, SVG_LPAD, SVG_TPAD, SVG_RPAD, SVG_BPAD } from '../data/observatory';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const m = t.manifesto;
const c = t.cosmos;
const obs = t.observatory;
// Build the ring set: each horizon gets a main ring, plus two faint ghost
// rings between it and the next — giving a sense of the vast empty space
// between scales. The last horizon has no ghosts after it.
const rings = c.address.flatMap((_, i) => {
  const list = [{ i, ghost: false }];
  if (i < c.address.length - 1) {
    list.push({ i: i + 0.25, ghost: true });
    list.push({ i: i + 0.5, ghost: true });
    list.push({ i: i + 0.75, ghost: true });
  }
  return list;
});
---
<BaseLayout title={`${m.title} — UniverLab`} description={`${m.title} — ${m.sub}.`} bg="cosmic" circadian>
  <section class="wrap opening">
    <span class="label">{m.kicker}</span>
    <h1>{m.title}</h1>
    <p class="sub label">{m.sub}</p>
    <blockquote class="prose">{m.epigraph}</blockquote>
  </section>

  <hr class="rule" />

  <section class="wrap section purpose-section">
    <span class="label">{m.purposeTitle}</span>
    <p class="purpose-body">{m.purposeBody}</p>
    <ol class="purpose-list">
      {m.purpose.map((p) => <li>{p}</li>)}
    </ol>
  </section>

  <!-- The cosmic perspective, now placed AFTER the manifesto's first argument:
       the scroll makes the wonder visceral — 13.8B years fall past, the horizon
       zooms out to the whole observable universe, and it collapses back onto a
       single observer who wonders it exists. It hands into the imperatives. -->
  <section class="cosmos-section">
    <div class="wrap cosmos-head">
      <span class="label">{c.kicker}</span>
    </div>
    <div class="cosmos-scrolly" data-cosmos>
      <div class="cosmos-sticky" style={`--levels:${c.address.length}; --tsteps:${c.timescales.length}`}>
        <div class="cosmos-stage">
          <!-- Phase 1: deep time as a decompressing scale bar. Scales stack
               largest-first; one is in focus (tall, lit) while the rest are
               hairlines. The focus descends as --tz travels 0 → N. -->
          <div class="tl-layer">
            <h3 class="tl-title cosmos-h">{c.timelineTitle}</h3>
            <ol class="tl-strata">
              {c.timescales.map(([span, name], idx) => (
                <li class="tl-stratum" style={`--i:${idx}`}>
                  <span class="tl-span mono">{span}</span>
                  <span class="tl-scale">{name}</span>
                </li>
              ))}
            </ol>
          </div>
          <!-- "You" — the last event of the timeline, outside tl-layer so it
               survives the fade. It slides to center with the dot, grows, then
               the text swaps to "Us" and it becomes the base of the pyramid. -->
          <div class="you-us">
            <span class="you-us-detail">{c.youDetail}</span>
            <span class="you-us-text">{c.you}</span>
          </div>
          <!-- The observer dot — falls as the comet, then slides to center
               with the "You" text, then shrinks as horizons expand. -->
          <span class="observer" aria-hidden="true"></span>
          <!-- Phase 2: zoom-out horizons — born from the bottom edge as a flat
               line, curve to a full circle, shrink to a point, vanish. Ghost
               rings between horizons suggest the vast empty space between
               scales. -->
          <div class="zo-layer">
            <div class="zo-rings">
              {rings.map((r) => (
                <span class={`zo-ring${r.ghost ? ' zo-ghost' : ''}`} style={`--i:${r.i}`}></span>
              ))}
            </div>
          </div>
          <!-- Phase labels overlay -->
          <div class="zo-title">
            <h3 class="cosmos-h">{c.addressTitle}</h3>
            <p class="address-intro">{c.addressIntro}</p>
          </div>
          <ol class="zo-labels">
            {c.address.map(([name, scale], i) => (
              <li class="zo-label" style={`--i:${i}`}>
                <span class="zo-name">{name}</span>
                <span class="zo-scale mono">{scale}</span>
              </li>
            ))}
          </ol>
          <!-- Scale gauge — a dimension line drawn across whichever ring is at
               full circle, labelled with that horizon's true size. It is the
               spatial echo of the deep-time numbers: a measure on the circle. -->
          <ol class="zo-gauges">
            {c.address.map(([name, scale], i) => (
              <li class="zo-gauge" style={`--i:${i}`}>
                <span class="zo-gauge-bar" aria-hidden="true"></span>
                <span class="zo-gauge-val mono">{scale}</span>
              </li>
            ))}
          </ol>
        </div>
        <!-- Accumulating address: an inverted pyramid that builds as you zoom
             out. Each horizon appears big when its ring reaches full circle,
             pushing previous levels down where they shrink — Us starts big,
             then Earth pushes it down, Solar System pushes Earth down, etc.
             The current level is always the biggest at top; past levels
             dwindle toward invisibility, showing how infinitesimally small
             we are within everything that contains us. -->
        <ol class="zo-stack">
          <li class="zo-stack-item zo-stack-us" style="--i:-0.5">
            <span class="zo-stack-name">{c.us}</span>
          </li>
          {c.address.map(([name], i) => (
            <li class="zo-stack-item" style={`--i:${i}`}>
              <span class="zo-stack-name">{name}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <section class="wrap section imperatives-section">
    <span class="label">{m.imperativesTitle}</span>
    <ol class="imperatives">
      {m.imperatives.map(([name, body]) => (
        <li>
          <span class="mono imp-name">{name}</span>
          <blockquote class="prose">{body}</blockquote>
        </li>
      ))}
    </ol>
    <p class="imp-note">{m.imperativesNote}</p>
  </section>

  <hr class="rule" />

  <section class="wrap section">
    <span class="label">{m.pillarsTitle}</span>
    <ol class="pillars">
      {m.pillars.map(([name, body], i) => (
        <li>
          <span class="mono p-num">{String(i + 1).padStart(2, '0')}</span>
          <div><h3>{name}</h3><p>{body}</p></div>
        </li>
      ))}
    </ol>
  </section>

  <hr class="rule" />

  <section class="wrap section">
    <span class="label">{m.pathTitle}</span>
    <ul class="path">
      {m.path.map(([from, to]) => (
        <li><span class="from">{from}</span><span class="arrow">→</span><span class="to">{to}</span></li>
      ))}
    </ul>
  </section>

  <hr class="rule" />

  <section class="wrap section works-section">
    <span class="label">{m.worksTitle}</span>
    <p class="works-body">{m.worksBody}</p>
    <ul class="works">
      {m.works.map(([name, desc]) => (
        <li>
          <span class="badge label">{m.worksBadge}</span>
          <h3>{name}</h3>
          <p>{desc}</p>
        </li>
      ))}
    </ul>
  </section>

  <hr class="rule" />

  <!-- Continuity Observatory — four data series that give the manifesto's
       imperatives empirical weight. Build-time static data; no runtime fetch.
       SVG charts include Y-axis labels and a hover crosshair (wired in the
       script block below). -->
  <section class="wrap section obs-section">
    <span class="label">{obs.kicker}</span>
    <p class="obs-intro">{obs.intro}</p>
    <div class="obs-grid">
      {series.map((s) => {
        const copy = obs.series[s.id as keyof typeof obs.series];
        const coords = toSvgCoords(s.points);
        const pts = toSvgPoints(coords);
        const rising = s.family !== 'fragility';
        const yVals = s.points.map((p) => p.value);
        const yMin = Math.min(...yVals);
        const yMax = Math.max(...yVals);
        const yTopPx = SVG_TPAD;
        const yBotPx = SVG_H - SVG_BPAD;
        const fmtY = (v: number) =>
          v >= 1000 ? Math.round(v).toLocaleString('en-US') : v % 1 !== 0 ? v.toFixed(1) : String(v);
        return (
          <article class={`obs-card obs-${s.family}`}>
            <header class="obs-card-head">
              <span class={`obs-dir mono ${rising ? 'obs-up' : 'obs-down'}`} aria-hidden="true">
                {rising ? '↑' : '↓'}
              </span>
              <h3 class="obs-title">{copy.title}</h3>
            </header>
            <div class="obs-chart">
              <svg
                viewBox={`0 0 ${SVG_W} ${SVG_H}`}
                class="obs-svg"
                data-pts={JSON.stringify(coords)}
                role="img"
                aria-label={copy.title}
              >
                {/* Horizontal guide lines at top/bottom of chart area */}
                <line x1={SVG_LPAD} y1={yTopPx} x2={SVG_W - SVG_RPAD} y2={yTopPx} class="obs-guide" />
                <line x1={SVG_LPAD} y1={yBotPx} x2={SVG_W - SVG_RPAD} y2={yBotPx} class="obs-guide" />
                {/* Y-axis value labels (left of chart) */}
                <text x={SVG_LPAD - 3} y={yTopPx + 5} text-anchor="end" class="obs-axis-label">{fmtY(yMax)}</text>
                <text x={SVG_LPAD - 3} y={yBotPx - 2} text-anchor="end" class="obs-axis-label">{fmtY(yMin)}</text>
                {/* X-axis year labels */}
                <text x={SVG_LPAD} y={SVG_H - 3} class="obs-axis-label">{s.points[0].year}</text>
                <text x={SVG_W - SVG_RPAD} y={SVG_H - 3} text-anchor="end" class="obs-axis-label">{s.points[s.points.length - 1].year}</text>
                {/* Data polyline */}
                <polyline points={pts} class={`obs-line obs-line-${s.family}`} />
                {/* Hover crosshair + dot — positioned by JS, hidden until hover */}
                <line class="obs-crosshair" x1="0" y1={yTopPx} x2="0" y2={yBotPx} visibility="hidden" />
                <circle class={`obs-dot obs-dot-${s.family}`} cx="0" cy="0" r="3" visibility="hidden" />
              </svg>
              {/* Strip below chart: updates year + value on hover */}
              <div class="obs-hover-strip">
                <span class="obs-hover-year mono">—</span>
                <span class="obs-hover-val mono"></span>
                <span class="obs-unit">{copy.unit}</span>
              </div>
            </div>
            <p class="obs-why">{copy.why}</p>
            <footer class="obs-attr">
              <span class="obs-attr-source">{obs.source}: {s.source}</span>
              <span class="obs-attr-license">{obs.license}: {s.license}</span>
            </footer>
          </article>
        );
      })}
    </div>
  </section>

  <hr class="rule" />

  <section class="wrap section closing">
    <p class="prose final">{m.closing}</p>
    <p class="note">{m.note}</p>
    <p class="label">{m.why}</p>
  </section>
</BaseLayout>

<style>
  .opening { padding-block: 4.5rem 3rem; display: flex; flex-direction: column; align-items: flex-start; gap: 0.9rem; }
  h1 { font-size: clamp(2.3rem, 6vw, 3.8rem); }
  .sub { margin: 0; }
  blockquote { margin: 1.4rem 0 0; font-family: var(--font-serif); font-style: italic; font-size: 1.15rem; color: var(--ink-dim); border-left: 1px solid var(--ink-faint); padding-left: 1.4rem; }
  .section { padding-block: 3rem; }

  /* Purpose & Vision — prose + numbered list */
  .purpose-section { max-width: 52rem; }
  .purpose-body {
    margin: 1.4rem 0 1.6rem;
    color: var(--ink-dim);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .purpose-list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: purpose;
  }
  .purpose-list li {
    counter-increment: purpose;
    display: flex;
    gap: 1.6rem;
    align-items: baseline;
    padding-block: 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.6;
  }
  .purpose-list li:first-child { border-top: 1px solid var(--line); }
  .purpose-list li::before {
    content: counter(purpose, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    flex-shrink: 0;
    padding-top: 0.22rem;
    min-width: 1.8rem;
  }

  /* The two imperatives — the core derivation, shown as quoted statements */
  .imperatives { list-style: none; margin: 1.8rem 0 0; padding: 0; display: grid; gap: 2rem; max-width: 52rem; }
  .imp-name { display: block; color: var(--ink); font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.7rem; }
  .imperatives blockquote { margin: 0; font-family: var(--font-serif); font-size: 1.12rem; line-height: 1.6; color: var(--ink-dim); border-left: 2px solid var(--ink-faint); padding-left: 1.3rem; }
  .imp-note { max-width: 52rem; margin: 2rem 0 0; color: var(--ink-faint); font-size: 0.92rem; line-height: 1.65; }

  .pillars { list-style: none; margin: 1.8rem 0 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr)); gap: 2.2rem 3rem; }
  .pillars li { display: flex; gap: 1.1rem; }
  .p-num { color: var(--ink-faint); font-size: 0.8rem; padding-top: 0.3rem; }
  .pillars h3 { font-family: var(--font-serif); font-style: italic; font-weight: 500; font-size: 1.08rem; margin-bottom: 0.4rem; }
  .pillars p { margin: 0; color: var(--ink-dim); font-size: 0.95rem; }
  /* The path of transformation — from → to pairs */
  .path { list-style: none; margin: 1.8rem 0 0; padding: 0; }
  .path li { display: grid; grid-template-columns: 1fr auto 1.4fr; gap: 1.2rem; align-items: baseline; padding-block: 0.8rem; border-bottom: 1px solid var(--line); }
  .path li:first-child { border-top: 1px solid var(--line); }
  .path .from { font-family: var(--font-serif); font-style: italic; color: var(--ink-dim); }
  .path .arrow { color: var(--ink-faint); }
  .path .to { color: var(--ink); }
  @media (max-width: 38rem) { .path li { grid-template-columns: 1fr; gap: 0.15rem; } .path .arrow { display: none; } }

  /* In development — future documents, as cards (mirrors astro-denoise) */
  .works-body { max-width: 46rem; margin: 1.2rem 0 0; color: var(--ink-dim); font-size: 0.98rem; line-height: 1.65; }
  .works { list-style: none; margin: 1.6rem 0 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr)); gap: 1rem; }
  .works li {
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border: 1px solid var(--line);
    border-left: 2px solid transparent;
    padding: 1.6rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    transition: background 0.15s ease, border-left-color 0.15s ease;
    backdrop-filter: blur(2px);
  }
  .works li:hover { background: var(--bg-raise); border-left-color: var(--accent); }
  .works .badge {
    display: inline-block; align-self: flex-start;
    padding: 0.15rem 0.45rem; margin-bottom: 0.3rem;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    border-radius: 2px; font-size: 0.65rem;
  }
  .works h3 { font-family: var(--font-serif); font-style: italic; font-weight: 500; font-size: 1.1rem; margin: 0; color: var(--ink); }
  .works p { color: var(--ink-dim); font-size: 0.92rem; margin: 0; line-height: 1.6; }

  /* Continuity Observatory — four interactive mini line-charts. Always 2×2
     grid, responsive to 1 column on mobile. SVG has baked-in Y/X axis labels
     and a JS-driven hover crosshair. */
  .obs-section { padding-block: 3rem; }
  .obs-intro { max-width: 52rem; margin: 1.2rem 0 2rem; color: var(--ink-dim); font-size: 1.02rem; line-height: 1.7; }
  .obs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  @media (max-width: 38rem) { .obs-grid { grid-template-columns: 1fr; } }

  .obs-card {
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    border: 1px solid var(--line);
    border-top: 2px solid var(--line);
    padding: 1.2rem 1.3rem 1rem;
    display: flex; flex-direction: column; gap: 0.85rem;
    transition: border-top-color 0.18s ease;
    backdrop-filter: blur(2px);
  }
  .obs-card.obs-flourishing { border-top-color: color-mix(in srgb, var(--accent) 55%, transparent); }
  .obs-card.obs-knowledge { border-top-color: color-mix(in srgb, var(--accent) 90%, transparent); }
  .obs-card.obs-fragility { border-top-color: #e0605a66; }

  .obs-card-head { display: flex; align-items: flex-start; gap: 0.55rem; }
  .obs-dir { font-size: 0.85rem; flex-shrink: 0; padding-top: 0.22rem; }
  .obs-up { color: var(--accent); }
  .obs-down { color: #e0605a; }
  .obs-title { font-family: var(--font-serif); font-style: italic; font-size: 1.02rem; font-weight: 500; margin: 0; color: var(--ink); line-height: 1.35; }

  /* Chart container + SVG */
  .obs-chart { display: flex; flex-direction: column; }
  .obs-svg { width: 100%; height: auto; display: block; cursor: crosshair; }

  /* Data polyline */
  .obs-line { fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .obs-line-flourishing { stroke: var(--accent); }
  .obs-line-knowledge { stroke: var(--accent); }
  .obs-line-fragility { stroke: #e0605a; }

  /* Y/X axis guide lines and labels (SVG elements) */
  .obs-guide { stroke: var(--line); stroke-width: 0.5; }
  .obs-axis-label { font-family: var(--font-mono); font-size: 7px; fill: var(--ink-faint); }

  /* Hover crosshair line + value dot */
  .obs-crosshair { stroke: var(--ink-faint); stroke-width: 0.8; stroke-dasharray: 2 2; }
  .obs-dot-flourishing, .obs-dot-knowledge { fill: var(--accent); }
  .obs-dot-fragility { fill: #e0605a; }

  /* Hover strip below SVG: shows year + value + unit when mouse is over chart */
  .obs-hover-strip {
    display: flex; align-items: baseline; gap: 0.35rem;
    padding: 0.3rem 0 0;
    min-height: 1.55rem;
    border-top: 1px solid var(--line);
  }
  .obs-hover-year { font-size: 0.74rem; color: var(--ink-dim); min-width: 2.5rem; }
  .obs-hover-val { font-size: 0.82rem; color: var(--accent); }
  .obs-card.obs-fragility .obs-hover-val { color: #e0605a; }
  .obs-unit { font-size: 0.65rem; color: var(--ink-faint); }

  .obs-why { margin: 0; color: var(--ink-dim); font-size: 0.9rem; line-height: 1.62; flex: 1; }

  .obs-attr {
    display: flex; flex-direction: column; gap: 0.1rem;
    padding-top: 0.6rem;
    border-top: 1px solid var(--line);
  }
  .obs-attr-source, .obs-attr-license {
    font-family: var(--font-mono); font-size: 0.65rem;
    letter-spacing: 0.02em; color: var(--ink-faint);
  }

  .closing { padding-block: 3.5rem 5rem; }
  .final { font-family: var(--font-serif); font-style: italic; font-size: 1.25rem; color: var(--ink); margin-bottom: 1.4rem; }
  .closing .note { max-width: 46rem; margin: 0 0 1.6rem; color: var(--ink-faint); font-size: 0.92rem; line-height: 1.65; }

  /* Cosmic perspective — a single scroll-driven scene. A comet falls through
     13.8B years of deep time, reaches "You" at the bottom, then that same
     point slides to center and becomes the observer of a zoom-out through
     cosmic scales — Earth to the observable universe. One --progress (0→1)
     drives the whole sequence:
       0 → 0.40   deep-time scale bar decompresses
       0.40 → 0.44  dot slides to center
       0.44 → 0.50  pause — "You" appears, holds, crossfades to "Us"
       0.50 → 1.0   zoom-out (rings expand past the observer) */
  .cosmos-section { padding-block: 3rem; }
  .cosmos-h {
    font-family: var(--font-serif); font-style: italic; font-weight: 500;
    font-size: 1.05rem; color: var(--ink); margin: 0;
  }
  .cosmos-scrolly { position: relative; margin-top: 1.6rem; }
  .cosmos-sticky {
    --progress: 0;
    --p: var(--progress);
    --dt: clamp(0, var(--p) / 0.40, 1);
    /* Deep-time focus: travels 0 → N across the scale bar, easing IN hard — the
       vast scales crawl (the universe really lingers), then it quickens sharply
       as time shrinks toward a human life. Big = slow, small = fast. */
    --tz: calc(var(--tsteps, 6) * var(--dt) * (0.15 + 0.85 * var(--dt)));
    --tx: clamp(0, (var(--p) - 0.40) / 0.04, 1);
    --hold: clamp(0, (var(--p) - 0.44) / 0.06, 1);
    --morph: clamp(0, (var(--p) - 0.47) / 0.03, 1);
    --zm: clamp(0, (var(--p) - 0.50) / 0.50, 1);
    --tl-fade: clamp(1 - (var(--p) - 0.36) / 0.08, 0, 1);
    --zo-fade: clamp((var(--p) - 0.47) / 0.03, 0, 1);
    /* Spatial zoom mirrors deep time, easing OUT — quick through the small
       scales (Earth, Solar System) and slowing as the horizons grow toward the
       observable universe. Same law as time: big = slow, small = fast. The
       zoom caps with the last horizon at --g 0.5 — a full circle that STAYS
       (the observable universe is the destination, it doesn't collapse). */
    --zoom: calc((var(--levels) - 0.5) * var(--zm) * (1.6 - 0.6 * var(--zm)));
    /* Real-time timer (0 → 1) that starts once the scroll cruise settles at
       the end. Used only to retire the final "93 Gly" cota after it has held
       long enough to read — the ring itself stays. See .zo-gauge. */
    --settle: 0;
    --wonder: clamp(0, (var(--p) - 0.95) / 0.04, 1);
  }
  /* Default height for touch (scroll-position mapping). JS overrides to a
     short section on desktop where wheel momentum drives the animation. */
  .cosmos-scrolly.scrolly { height: 600vh; margin-top: 0; }
  .cosmos-scrolly.scrolly .cosmos-sticky {
    position: sticky; top: 0; height: 100vh;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .cosmos-stage {
    position: relative;
    width: 100%; max-width: min(42rem, 68vh);
    height: 72vh; min-height: 26rem;
    margin: 0 auto;
    text-align: center;
  }
  /* Subtle depth gradient — a faint radial glow from center that intensifies
     with zoom, giving the rings a sense of receding into deep space. */
  .cosmos-scrolly.scrolly .cosmos-stage::after {
    content: ''; position: absolute; inset: -20%;
    background: radial-gradient(circle at center,
      color-mix(in srgb, var(--accent) calc(var(--zm) * 6%), transparent) 0%,
      transparent 60%);
    pointer-events: none; z-index: 0;
  }

  /* Phase 1: deep time as a decompressing scale bar. A vertical stack of time
     scales, the largest (the age of the universe) at the top. Each band's
     height is proportional to how close it is to the focus --tz: the focused
     band swells open ("decompresses") and is lit; the rest are squeezed to
     hairlines. As --tz descends 0 → N the open fold travels down the bar, so
     ever-finer scales of time unfold out of the compressed stack — the
     immensity stays crushed above and below the one scale you are reading. */
  .tl-layer { position: absolute; inset: 0; opacity: var(--tl-fade); }
  .tl-title { position: absolute; top: 0; left: 0; right: 0; }
  .tl-strata {
    position: absolute; top: 16%; bottom: 6%; left: 50%;
    transform: translateX(-50%);
    width: min(38rem, 94%);
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column;
  }
  .tl-stratum {
    --d: calc(var(--tz) - var(--i));
    --ad: max(var(--d), calc(-1 * var(--d)));
    --f: clamp(0, 1 - var(--ad), 1);
    flex: calc(1 / (1 + var(--ad) * var(--ad) * 3)) 1 0;
    position: relative; min-height: 1px; overflow: hidden;
    display: flex; flex-direction: column; justify-content: center;
    align-items: center; gap: 0.1rem;
    border-top: 1px solid
      color-mix(in srgb, var(--accent) calc(var(--f) * 60%), var(--line));
  }
  .tl-stratum:first-child { border-top: 0; }
  .tl-span {
    font-family: var(--font-mono);
    font-size: calc(0.82rem + var(--f) * var(--f) * 1.15rem);
    line-height: 1.1; letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--accent) calc(var(--f) * 100%), var(--ink-faint));
    opacity: clamp(0, var(--f) * 1.5, 1);
    white-space: nowrap;
  }
  .tl-scale {
    font-family: var(--font-serif); font-style: italic;
    font-size: calc(0.82rem + var(--f) * 0.45rem);
    color: var(--ink-dim);
    opacity: clamp(0, (var(--f) - 0.12) * 1.7, 1);
    white-space: nowrap;
  }

  /* The observer — the single dot that falls as the comet through the
     timeline, then slides to center, then shrinks as horizons expand. */
  .observer {
    position: absolute; left: 50%;
    top: calc(12% + var(--dt) * 76% - var(--tx) * 38%);
    width: 13px; height: 13px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 18px 4px color-mix(in srgb, var(--accent) 65%, transparent);
    --dot-scale: calc(1 - clamp(0, (var(--zm) - 0.1) / 0.3, 1) * 0.9);
    transform: translate(-50%, -50%) scale(var(--dot-scale));
    /* the dot travels all the way to the centre of the rings, even though the
       "You/Us" label settles a little lower */
    opacity: calc(1 - clamp(0, (var(--zm) - 0.3) / 0.2, 1));
    z-index: 3;
  }

  /* "You" — the last timeline event, outside tl-layer so it survives the
     fade. Sits at the bottom of the timeline like other events, then slides
     to center with the dot, growing. At center it crossfades with "Us" (the
     first item of the pyramid stack, positioned at center via transform).
     When zoom begins, "Us" releases from the center transform and joins the
     pyramid flex flow naturally. */
  .you-us {
    position: absolute; left: 50%;
    top: calc(88% - var(--tx) * 15%);
    transform: translate(-50%, -50%);
    text-align: center; z-index: 4; pointer-events: none;
    opacity: calc(clamp(0, (var(--dt) - 0.92) * 12, 1) * (1 - var(--morph)));
  }
  .you-us-text {
    display: block;
    font-family: var(--font-serif); font-style: italic;
    font-size: calc(1rem + var(--tx) * 4rem);
    color: var(--accent); white-space: nowrap; line-height: 1.1;
  }
  .you-us-detail {
    display: block;
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.8rem; color: var(--ink-faint); line-height: 1.35;
    margin-bottom: 0.18rem;
    opacity: calc(clamp(0, (var(--dt) - 0.96) * 12, 1) * (1 - var(--tx)));
    transform: translateY(calc((1 - clamp(0, (var(--dt) - 0.96) * 12, 1)) * 4px));
  }

  /* Phase 2: zoom-out horizons. Each ring's lifecycle (--g: 0→1):
       0 → 0.5   born from below as a flat line, rises and curves into a full
                 centered circle (scale 12 → 1, translateY 500% → 0)
       0.5 → 1   shrinks in place to a point (scale 1 → 0.03, translateY 0)
     Rings overlap: each starts appearing 0.15 before its turn, so the next
     line is already rising as the current ring collapses to a point. Ghost
     rings between horizons suggest the vast empty space between scales. */
  .zo-layer { position: absolute; inset: 0; opacity: var(--zo-fade); }
  .zo-rings { position: absolute; inset: 0; }
  .zo-ring {
    --i: 0;
    position: absolute; top: 50%; left: 50%;
    width: 100%; aspect-ratio: 1; border-radius: 50%;
    border: 1px solid var(--ink-faint);
    transform: translate(-50%, -50%);
  }
  .cosmos-scrolly.scrolly .zo-ring {
    --g: calc(var(--zoom) - var(--i));
    --gc: clamp(0, var(--g), 1);
    --rise: clamp(0, var(--gc) * 2, 1);
    --fall: clamp(0, (var(--gc) - 0.5) * 2, 1);
    --ir: calc(1 - var(--rise));
    --born: clamp(0, (var(--g) + 0.15) / 0.15, 1);
    --dead: clamp(0, (var(--g) - 1) / 0.1, 1);
    --vis: calc(var(--born) * (1 - var(--dead)));
    --here: clamp(0, 1 - max(calc(var(--gc) - 0.5), calc(0.5 - var(--gc))) * 3, 1);
    transform: translate(-50%, -50%)
               translateY(calc(500% * var(--ir) * var(--ir) * var(--ir)))
               scale(calc(1 + 11 * var(--ir) * var(--ir) - 0.97 * var(--fall) * var(--fall)));
    opacity: var(--vis);
    border-color: color-mix(in srgb, var(--accent) calc(var(--here) * 70%), var(--ink-faint));
    border-width: calc(1px + var(--here) * 1.5px);
    box-shadow: 0 0 calc(var(--here) * 26px) color-mix(in srgb, var(--accent) calc(var(--here) * 42%), transparent);
  }
  /* Ghost rings — same lifecycle, but faint and unhighlighted. */
  .cosmos-scrolly.scrolly .zo-ring.zo-ghost {
    border-color: color-mix(in srgb, var(--ink-faint) 22%, transparent);
    border-width: 0.5px;
    box-shadow: none;
    opacity: calc(var(--vis) * 0.3);
  }

  /* Phase titles + zoom labels — centered overlays, crossfaded by phase. */
  .zo-title {
    position: absolute; top: calc(4% + 20px); left: 0; right: 0;
    text-align: center; pointer-events: none;
    opacity: var(--zo-fade);
  }
  .address-intro { margin: 0; color: var(--ink-faint); font-size: 0.9rem; letter-spacing: 0.02em; }
  /* In the animation the zoom-out header is a single quiet line ("Zoom out") —
     the "cosmic address" title only shows in the static (no-JS) fallback. */
  .cosmos-scrolly.scrolly .zo-title .cosmos-h { display: none; }
  .zo-labels {
    position: absolute; bottom: 8%; left: 0; right: 0;
    text-align: center; pointer-events: none;
    opacity: var(--zo-fade);
  }
  .zo-label {
    --g: calc(var(--zoom) - var(--i));
    --vis: clamp(0, 1 - max(calc(var(--g) - 0.5), calc(0.5 - var(--g))) * 2.5, 1);
    position: absolute; left: 0; right: 0; bottom: 0;
    opacity: var(--vis);
    transform: translateY(calc((1 - var(--vis)) * 12px));
  }
  .zo-name {
    display: block; font-family: var(--font-serif); font-style: italic;
    font-size: clamp(1.1rem, 3.5vw, 1.5rem); color: var(--ink);
  }
  .zo-scale {
    display: block; margin-top: 0.15rem;
    font-size: 0.74rem; letter-spacing: 0.1em; color: var(--ink-faint);
  }

  /* Accumulating address — a centered inverted pyramid that builds as you
     zoom out. Each horizon appears big when its ring reaches full circle,
     then shrinks as you continue past it and the next, wider horizon stacks
     above. Us starts big when the dot reaches center, then Earth pushes it
     down, Solar System pushes Earth down, etc. The current level is always
     the biggest at top; past levels dwindle toward invisibility — showing
     how infinitesimally small we are within everything that contains us. */
  .cosmos-scrolly.scrolly .zo-labels { display: none; }
  /* The stack is anchored at a fixed point a little below centre — exactly
     where "You" lands and morphs into "Us". Us is the first item, at the
     bottom of the column-reverse flow, so it stays put there; each new, wider
     horizon rises above it while the older levels shrink in place. */
  .zo-stack {
    position: absolute; bottom: 28%; left: 50%;
    transform: translateX(-50%);
    list-style: none; margin: 0; padding: 0;
    pointer-events: none; z-index: 3;
    display: flex; flex-direction: column-reverse;
    align-items: center;
    gap: 0.3rem;
    text-align: center;
    opacity: calc(var(--zo-fade) * var(--morph));
  }
  /* --g is how far zoom has travelled past this level (its "age"). The newest
     level (g≈0) is the largest and accent-lit; each older level is divided
     down, so two levels are never the same size. --appear ramps the size in
     fast, so a level enters at full size (never tiny beside an older one);
     --vis fades opacity a touch more gently. "observable universe" — the last
     and longest label — reaches ~10rem and spills past the ring, by design. */
  .zo-stack-item {
    --g: calc(var(--zoom) - var(--i));
    --appear: clamp(0, var(--g) / 0.04, 1);
    --vis: clamp(0, var(--g) / 0.12, 1);
    --sz: calc(10rem / (1 + clamp(0, var(--g), 8) * 1.2));
    --scale: 1;
    opacity: calc(var(--vis) * (1 - clamp(0, (var(--g) - 3) / 5, 1) * 0.55));
    transition: opacity 0.3s linear;
  }
  .zo-stack-name {
    font-family: var(--font-serif); font-style: italic;
    font-size: calc(var(--sz) * var(--appear) * var(--scale));
    line-height: 1.1;
    color: var(--ink-dim);
    white-space: nowrap;
  }
  /* Only "Us" (the first item, smallest, at the bottom) carries the accent —
     every wider horizon, up to "observable universe", stays in quiet ink. */
  .zo-stack-item:first-child .zo-stack-name { color: var(--accent); }
  /* "Us" stays fully lit (not dimmed by age) and sits a little smaller — 60%
     of what the size curve alone would give it. */
  .zo-stack-us { --scale: 0.6; opacity: var(--vis); }

  /* Scale gauge — each horizon's true diameter, drawn as a dimension line that
     appears only while its ring is at full circle (g ≈ 0.5), then fades as the
     ring shrinks past. The spatial counterpart to the deep-time numbers. */
  .zo-gauges { position: absolute; inset: 0; pointer-events: none; z-index: 2; list-style: none; margin: 0; padding: 0; }
  .zo-gauge {
    --g: calc(var(--zoom) - var(--i));
    /* Same diameter law as the ring it measures, so the cota grows and shrinks
       locked to its circle. */
    --gc: clamp(0, var(--g), 1);
    --rise: clamp(0, calc(var(--gc) * 2), 1);
    --fall: clamp(0, calc((var(--gc) - 0.5) * 2), 1);
    --ir: calc(1 - var(--rise));
    --rs: calc(1 + 11 * var(--ir) * var(--ir) - 0.97 * var(--fall) * var(--fall));
    /* Appears just before its ring reaches full circle and holds while the
       ring is near-full. Earlier horizons then fade as their ring collapses
       past (g > 0.5). The final horizon's ring never collapses, so its cota
       would linger forever — --retire (driven by the real-time --settle timer
       once scroll ends) fades it out after it has held long enough to read. */
    --vis: clamp(0, min(calc((var(--g) - 0.35) / 0.15), calc((1.05 - var(--g)) / 0.25)), 1);
    position: absolute; top: 50%; left: 50%;
    width: calc(88% * var(--rs)); transform: translate(-50%, -50%);
    /* Base visibility is clamped to [0,1] FIRST — --zo-fade overshoots well
       past 1 in the collapse range, so multiplying the retire factor into the
       raw product would keep opacity pinned at 1 until retire ≈ 1 (a hard pop).
       The (1 - clamp(...)) retire factor then holds the cota (settle 0 → 0.4)
       and fades it out (0.4 → 1), driven by the real-time --settle timer. */
    opacity: calc(clamp(0, var(--vis) * var(--zo-fade), 1) * (1 - clamp(0, (var(--settle) - 0.4) / 0.6, 1)));
  }
  .zo-gauge-bar {
    display: block; height: 1px; position: relative;
    background: color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .zo-gauge-bar::before, .zo-gauge-bar::after {
    content: ''; position: absolute; top: -3px; width: 1px; height: 7px;
    background: color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .zo-gauge-bar::before { left: 0; }
  .zo-gauge-bar::after { right: 0; }
  .zo-gauge-val {
    position: absolute; left: 50%; bottom: calc(100% + 0.35rem);
    transform: translateX(-50%);
    font-size: 0.66rem; letter-spacing: 0.06em; white-space: nowrap;
    color: color-mix(in srgb, var(--accent) 80%, var(--ink-dim));
    background: var(--bg); padding: 0 0.5rem;
  }

  /* Closing beat — the wonder line fades in at the very end, centred inside the
      final horizon, naming what the scene has been building toward. */
  .scene-wonder {
    position: absolute; left: 50%; top: 50%;
    transform: translate(-50%, -50%) translateY(calc((1 - var(--wonder)) * 8px));
    margin: 0; width: 80%; max-width: 22rem;
    font-family: var(--font-serif); font-style: italic;
    font-size: clamp(1.05rem, 3vw, 1.35rem); line-height: 1.4;
    color: var(--ink); text-wrap: balance;
    opacity: var(--wonder); z-index: 4; pointer-events: none;
  }

  /* Static fallback (no JS / reduced motion): both phases as flat, fully-lit
     boards — a centered timeline list, then a nested diagram + address list. */
  .cosmos-scrolly:not(.scrolly) .cosmos-sticky { height: auto; display: block; }
  .cosmos-scrolly:not(.scrolly) .cosmos-stage { height: auto; min-height: 0; }
  .cosmos-scrolly:not(.scrolly) .tl-layer,
  .cosmos-scrolly:not(.scrolly) .zo-layer { position: static; opacity: 1; }
  .cosmos-scrolly:not(.scrolly) .tl-title { position: static; margin-bottom: 1.4rem; opacity: 1; }
  .cosmos-scrolly:not(.scrolly) .tl-strata {
    position: static; transform: none; width: auto; display: block;
  }
  .cosmos-scrolly:not(.scrolly) .tl-stratum {
    flex: none; overflow: visible;
    flex-direction: row; justify-content: space-between; align-items: baseline;
    gap: 1rem; padding-block: 0.6rem;
    border-top: 1px solid var(--line);
  }
  .cosmos-scrolly:not(.scrolly) .tl-stratum:first-child { border-top: 1px solid var(--line); }
  .cosmos-scrolly:not(.scrolly) .tl-span { font-size: 0.92rem; color: var(--accent); opacity: 1; }
  .cosmos-scrolly:not(.scrolly) .tl-scale { font-size: 0.92rem; opacity: 1; }
  .cosmos-scrolly:not(.scrolly) .observer { display: none; }
  .cosmos-scrolly:not(.scrolly) .you-us {
    position: static; transform: none; opacity: 1;
    margin-bottom: 1.2rem;
  }
  .cosmos-scrolly:not(.scrolly) .you-us-text { font-size: 1rem; }
  .cosmos-scrolly:not(.scrolly) .you-us-you { opacity: 0; }
  .cosmos-scrolly:not(.scrolly) .you-us-us { position: static; opacity: 1; }
  .cosmos-scrolly:not(.scrolly) .you-us-detail { opacity: 1; transform: none; }
  .cosmos-scrolly:not(.scrolly) .zo-rings {
    position: relative; width: min(22rem, 68vw); margin: 0 auto 1.4rem;
    aspect-ratio: 1;
  }
  .cosmos-scrolly:not(.scrolly) .zo-ring {
    transform: translate(-50%, -50%) scale(calc(1 - var(--i) * 0.12));
    border-color: color-mix(in srgb, var(--ink-faint) 55%, transparent);
    opacity: 1;
  }
  .cosmos-scrolly:not(.scrolly) .zo-ring.zo-ghost { display: none; }
  .cosmos-scrolly:not(.scrolly) .zo-gauges { display: none; }
  .cosmos-scrolly:not(.scrolly) .zo-title { position: static; opacity: 1; margin-bottom: 1rem; }
  .cosmos-scrolly:not(.scrolly) .zo-labels {
    position: static; opacity: 1; list-style: none; margin: 0; padding: 0; max-width: 30rem;
  }
  .cosmos-scrolly:not(.scrolly) .zo-label {
    position: static; opacity: 1; transform: none;
    display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;
    padding-block: 0.55rem; border-bottom: 1px solid var(--line);
  }
  .cosmos-scrolly:not(.scrolly) .zo-label:first-child { border-top: 1px solid var(--line); }
  .cosmos-scrolly:not(.scrolly) .zo-label:first-child .zo-name { color: var(--accent); }
  .cosmos-scrolly:not(.scrolly) .zo-name { font-size: 0.92rem; }
  .cosmos-scrolly:not(.scrolly) .zo-scale { display: inline; margin: 0; }
  .cosmos-scrolly:not(.scrolly) .zo-stack {
    position: static; opacity: 1; list-style: none; margin: 0; padding: 0; max-width: 30rem;
    transform: none; display: block;
  }
  .cosmos-scrolly:not(.scrolly) .zo-stack-us { transform: none; }
  .cosmos-scrolly:not(.scrolly) .zo-stack-item {
    position: static; opacity: 1; transform: none;
    display: flex; justify-content: space-between; gap: 1rem; align-items: baseline;
    padding-block: 0.55rem; border-bottom: 1px solid var(--line);
  }
  .cosmos-scrolly:not(.scrolly) .zo-stack-item:first-child { border-top: 1px solid var(--line); }
  .cosmos-scrolly:not(.scrolly) .zo-stack-item:first-child .zo-stack-name { color: var(--accent); }
  .cosmos-scrolly:not(.scrolly) .zo-stack-name { font-size: 0.92rem; }
  .cosmos-scrolly:not(.scrolly) .scene-wonder {
    position: static; opacity: 1; transform: none;
    width: auto; max-width: 34rem; margin: 1.6rem auto 0; text-align: center;
  }

  @media (max-width: 34rem) {
    .cosmos-stage { max-width: min(100%, 68vh); }
  }

  /* Scrollytelling reveal — pure CSS scroll-driven. Every block and list item
     rises and brightens as it scrolls up into the reading zone, tied to scroll
     position: the effect plays live as you move and reverses when you scroll
     back, so the page guides you idea by idea. Each list item gets its own
     view() timeline, so they arrive in turn as the list passes. Where scroll
     timelines are unsupported (or motion is reduced) nothing animates and the
     page is fully visible — progressive enhancement, no JS needed. */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .opening > *,
      .section > *,
      .purpose-list li,
      .imperatives li,
      .pillars li,
      .path li,
      .works li {
        animation: step-rise linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 28%;
      }
      /* The lists animate their items, so don't also animate the <ol> block. */
      .purpose-list, .imperatives, .pillars, .path { animation: none; }
      /* Dim sibling lines once they leave the top, keeping the eye on the
         block currently in the reading zone. */
      .imperatives li, .pillars li, .path li, .purpose-list li {
        animation: step-rise linear both, step-dim linear both;
        animation-timeline: view(), view();
        animation-range: entry 0% cover 28%, exit 40% exit 100%;
      }
    }
  }
  @keyframes step-rise {
    from { opacity: 0.12; transform: translateY(36px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes step-dim {
    from { opacity: 1; }
    to   { opacity: 0.35; }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isTouch = 'ontouchstart' in window && navigator.maxTouchPoints > 0;

  const cosmos = document.querySelector<HTMLElement>('[data-cosmos]');
  const sticky = cosmos?.querySelector<HTMLElement>('.cosmos-sticky');

  if (cosmos && sticky && !reduce) {
    cosmos.classList.add('scrolly');

    // The scroll-driven zoom (see --zoom) caps out with the final horizon
    // right as it reaches full size — there's no more scroll left to carry
    // it into the collapse-and-fade every earlier ring gets. Once progress
    // settles at 1, run that same collapse on a real-time clock instead, so
    // the last ring and its cota still hold briefly, then shrink and fade.
    const SETTLE_MS = 4000;
    let settleStart: number | null = null;
    const setSettling = (active: boolean) => {
      if (active) {
        if (settleStart === null) settleStart = performance.now();
      } else if (settleStart !== null) {
        settleStart = null;
        sticky.style.setProperty('--settle', '0');
      }
    };
    const tickSettle = (time: number) => {
      if (settleStart !== null) {
        const t = Math.min((time - settleStart) / SETTLE_MS, 1);
        sticky.style.setProperty('--settle', t.toFixed(4));
      }
      requestAnimationFrame(tickSettle);
    };
    requestAnimationFrame(tickSettle);

    if (isTouch) {
      // Touch: map scroll position directly to progress.
      let ticking = false;
      const update = () => {
        const total = cosmos.offsetHeight - window.innerHeight;
        const scrolled = Math.min(Math.max(-cosmos.getBoundingClientRect().top, 0), Math.max(total, 1));
        const p = total > 0 ? scrolled / total : 0;
        sticky.style.setProperty('--progress', p.toFixed(4));
        setSettling(p >= 0.999);
        ticking = false;
      };
      const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      update();
    } else {
      // Desktop: cruise-control wheel capture. One scroll down starts the
      // animation (~25s end-to-end); more scroll accelerates it hard; scroll up
      // reverses immediately and fast — a quick rewind back to the start. The
      // wheel is captured while the stage is pinned and released at the
      // boundaries so the user can scroll past naturally.
      cosmos.style.height = '200vh';

      let progress = 0;
      let velocity = 0;
      const BASE = 1 / 1500;       // ~25s forward cruise at 60fps
      const MAX_FWD = BASE * 5;    // hard forward acceleration (~5s end-to-end)
      const REV_BASE = BASE * 5;   // one scroll up retreats fast straight away
      const MAX_REV = BASE * 14;   // ...building to a near-instant rewind (~2s)
      const KICK = 0.00004;        // snappier forward response per wheel unit
      const KICK_REV = 0.00012;    // reverse builds even faster than forward
      const SETTLE = 0.00005;      // velocity decay toward base per tick

      const isActive = () => {
        const r = cosmos.getBoundingClientRect();
        return r.top <= 0 && r.bottom >= window.innerHeight;
      };

      // Auto-start the animation when the cosmos section is framed (pinned on
      // screen). This covers keyboard navigation and any non-wheel scroll that
      // lands on the section — the observer fires once, then disconnects.
      let autoStarted = false;
      const autoStart = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting && !autoStarted && velocity === 0) {
            autoStarted = true;
            velocity = BASE;
          }
        }
      }, { threshold: 0.1 });
      autoStart.observe(cosmos);

      // Always bound — check active inside, so there's no race between
      // entering the section and the first wheel event.
      const onWheel = (e: WheelEvent) => {
        if (!isActive()) {
          // Snap progress when out of view so re-entry starts from the right
          // state (0 if below, 1 if above).
          const r = cosmos.getBoundingClientRect();
          if (r.bottom <= 0 && progress < 1) { progress = 1; sticky.style.setProperty('--progress', '1'); }
          if (r.top >= window.innerHeight && progress > 0) { progress = 0; sticky.style.setProperty('--progress', '0'); }
          return;
        }

        // At boundaries, release only in the "past" direction:
        //   progress=1 + scroll down → release (continue past)
        //   progress=0 + scroll up   → release (go back up)
        //   progress=1 + scroll up   → capture (reverse animation)
        //   progress=0 + scroll down → capture (start animation)
        if (progress >= 0.999 && e.deltaY > 0) return;
        if (progress <= 0.001 && e.deltaY < 0) return;

        e.preventDefault();

        if (e.deltaY > 0) {
          // Forward: kick to cruise, then accelerate hard toward the cap
          if (velocity < BASE) velocity = BASE;
          else velocity = Math.min(velocity + e.deltaY * KICK, MAX_FWD);
        } else {
          // Up: retreat fast immediately (no "stop first"), then build to a
          // near-instant rewind — scrolling back collapses the scene quickly.
          if (velocity > -REV_BASE) velocity = -REV_BASE;
          else velocity = Math.max(velocity - Math.abs(e.deltaY) * KICK_REV, -MAX_REV);
        }
      };

      window.addEventListener('wheel', onWheel, { passive: false });

      let lastTime = 0;
      const tick = (time: number) => {
        if (!lastTime) lastTime = time;
        const dt = Math.min((time - lastTime) / 16.67, 3);
        lastTime = time;

        // Velocity settles toward base speed (or -base). 0 stays 0 (stopped).
        if (velocity > BASE) velocity = Math.max(velocity - SETTLE * dt, BASE);
        else if (velocity < -BASE) velocity = Math.min(velocity + SETTLE * dt, -BASE);

        // Integrate
        if (velocity !== 0) {
          progress += velocity * dt;
          if (progress <= 0) { progress = 0; velocity = 0; }
          if (progress >= 1) { progress = 1; velocity = 0; }
          sticky.style.setProperty('--progress', progress.toFixed(4));
        }

        setSettling(progress >= 1);
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  }

  // The section-by-section reveal is pure CSS (animation-timeline: view()) — no
  // JS needed; it degrades to a fully-visible page where unsupported.
</script>

<script>
  // Observatory interactive hover: crosshair + data strip for each chart.
  // SVG_W / SVG_LPAD must match the constants in observatory.ts.
  const OBS_W = 280, OBS_LPAD = 38, OBS_RPAD = 4;

  document.querySelectorAll<SVGSVGElement>('.obs-svg').forEach((svg) => {
    const raw = svg.dataset.pts;
    if (!raw) return;
    type Coord = { year: number; value: number; x: number; y: number };
    let pts: Coord[];
    try { pts = JSON.parse(raw); } catch { return; }
    if (!pts.length) return;

    const crosshair = svg.querySelector<SVGLineElement>('.obs-crosshair');
    const dot = svg.querySelector<SVGCircleElement>('.obs-dot');
    const chart = svg.closest<HTMLElement>('.obs-chart');
    const yearEl = chart?.querySelector<HTMLElement>('.obs-hover-year');
    const valEl = chart?.querySelector<HTMLElement>('.obs-hover-val');

    const closestPt = (svgX: number) =>
      pts.reduce((best, p) =>
        Math.abs(p.x - svgX) < Math.abs(best.x - svgX) ? p : best);

    const fmtVal = (v: number) =>
      v >= 1000 ? v.toLocaleString() : v % 1 !== 0 ? v.toFixed(1) : String(v);

    const toSvgX = (clientX: number) => {
      const r = svg.getBoundingClientRect();
      return (clientX - r.left) * (OBS_W / r.width);
    };

    const showPt = (svgX: number) => {
      const p = closestPt(svgX);
      crosshair?.setAttribute('x1', p.x.toFixed(1));
      crosshair?.setAttribute('x2', p.x.toFixed(1));
      crosshair?.removeAttribute('visibility');
      dot?.setAttribute('cx', p.x.toFixed(1));
      dot?.setAttribute('cy', p.y.toFixed(1));
      dot?.removeAttribute('visibility');
      if (yearEl) yearEl.textContent = String(p.year);
      if (valEl) valEl.textContent = fmtVal(p.value);
    };

    const hidePt = () => {
      crosshair?.setAttribute('visibility', 'hidden');
      dot?.setAttribute('visibility', 'hidden');
      if (yearEl) yearEl.textContent = '—';
      if (valEl) valEl.textContent = '';
    };

    svg.addEventListener('mousemove', (e) => {
      const svgX = toSvgX(e.clientX);
      if (svgX < OBS_LPAD || svgX > OBS_W - OBS_RPAD) { hidePt(); return; }
      showPt(svgX);
    });

    svg.addEventListener('mouseleave', hidePt);

    svg.addEventListener('touchmove', (e) => {
      if (e.touches.length !== 1) return;
      e.preventDefault();
      const svgX = toSvgX(e.touches[0].clientX);
      if (svgX < OBS_LPAD || svgX > OBS_W - OBS_RPAD) { hidePt(); return; }
      showPt(svgX);
    }, { passive: false });

    svg.addEventListener('touchend', hidePt);
  });
</script>

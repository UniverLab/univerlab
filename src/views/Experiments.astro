---
import BaseLayout from '../layouts/BaseLayout.astro';
import { experiments } from '../lib/experiments';
import { getLang, useTranslations, localizePath } from '../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
---
<BaseLayout title={`${t.experimentsIndex.title} — UniverLab`} bg="cosmic" bgColor="#a78bfa">
  <section class="wrap head">
    <span class="label">{t.experimentsIndex.kicker}</span>
    <h1>{t.experimentsIndex.title}</h1>
    <p class="prose intro">{t.experimentsIndex.intro}</p>
  </section>

  <div class="wrap">
    <ol class="list">
      {experiments.map((exp) => {
        const e = (t.experiments as any)[exp.id];
        return (
          <li style={`--essence: var(${exp.essenceVar})`}>
            <a href={localizePath(`/experiments/${exp.id}`, lang)} class="row">
              <span class="label num">{exp.number}</span>
              <span class="name">{exp.name}</span>
              <span class="tagline">{e.tagline}</span>
              <span class="label status">{(t.status as any)[exp.status]}</span>
            </a>
          </li>
        );
      })}
    </ol>
  </div>
</BaseLayout>

<style>
  .head { padding-block: 4rem 2.5rem; }
  .head h1 { font-size: clamp(2rem, 5vw, 3rem); margin-block: 0.6rem 1rem; }
  .intro { color: var(--ink-dim); }
  .list { list-style: none; margin: 0 0 5rem; padding: 0; border-top: 1px solid var(--line); }
  .row {
    display: grid; grid-template-columns: 6rem 11rem 1fr 7rem; gap: 1.5rem;
    align-items: baseline; padding-block: 1.3rem; border-bottom: 1px solid var(--line);
    text-decoration: none; transition: background 0.15s ease;
  }
  .row:hover { background: var(--bg-raise); }
  .row:hover .name { color: var(--essence); }
  .num { color: var(--essence); }
  .name { font-size: 1.15rem; transition: color 0.15s ease; }
  .tagline { color: var(--ink-dim); font-size: 0.95rem; }
  .status { text-align: right; }
  @media (max-width: 50rem) { .row { grid-template-columns: 5rem 1fr 5rem; } .tagline { display: none; } }
</style>

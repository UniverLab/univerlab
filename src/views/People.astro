---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const p = t.people;
---
<BaseLayout title={`${p.title} — UniverLab`} bg="cosmic" bgColor="#a78bfa">
  <section class="wrap head">
    <span class="label">{p.kicker}</span>
    <h1>{p.title}</h1>
  </section>

  <div class="wrap">
    <ul class="list">
      <li>
        <span class="label">{p.founder.role}</span>
        <h3>{p.founder.name}</h3>
        <p>{p.founder.body}</p>
        <a class="label" href="https://github.com/JheisonMB">{p.founder.link}</a>
      </li>
      <li>
        <span class="label">{p.ai.role}</span>
        <h3>{p.ai.name}</h3>
        <p set:html={p.ai.body} />
      </li>
      <li>
        <span class="label">{p.contributors.role}</span>
        <h3>{p.contributors.name}</h3>
        <p>{p.contributors.body}</p>
        <a class="label" href="https://github.com/UniverLab">{p.contributors.link}</a>
      </li>
    </ul>
  </div>
</BaseLayout>

<style>
  .head { padding-block: 4rem 2.5rem; }
  .head h1 { font-size: clamp(2rem, 5vw, 3rem); margin-top: 0.6rem; }
  .list { list-style: none; margin: 0 0 5rem; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr)); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .list li { background: var(--bg); padding: 1.8rem; display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }
  .list h3 { font-size: 1.15rem; }
  .list p { color: var(--ink-dim); font-size: 0.95rem; margin: 0; }
  :global(.list p a) { color: var(--ink); }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n';
const lang = getLang(Astro.url);
const t = useTranslations(lang);
---
<BaseLayout title={`${t.research.title} — UniverLab`} bg="starfield" bgColor="#a78bfa">
  <section class="wrap head">
    <span class="label">{t.research.kicker}</span>
    <h1>{t.research.title}</h1>
    <p class="prose intro" set:html={t.research.intro} />
  </section>

  <div class="wrap">
    <ul class="list">
      {t.research.items.map(([name, desc]) => (
        <li>
          <h3>{name}</h3>
          <p>{desc}</p>
          <span class="label">{t.common.inPreparation}</span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .head { padding-block: 4rem 2.5rem; }
  .head h1 { font-size: clamp(2rem, 5vw, 3rem); margin-block: 0.6rem 1rem; }
  .intro { color: var(--ink-dim); }
  :global(.intro a) { color: var(--ink); }
  .list { list-style: none; margin: 0 0 5rem; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .list li { background: var(--bg); padding: 1.6rem; }
  .list h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .list p { color: var(--ink-dim); font-size: 0.95rem; margin: 0 0 1rem; }
</style>
